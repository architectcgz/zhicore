package com.zhicore.post.infrastructure.service;

import com.zhicore.common.cache.HotDataIdentifier;
import com.zhicore.common.config.CacheProperties;
import com.zhicore.post.domain.model.PostContent;
import cache.infrastructure.com.zhicore.content.PostRedisKeys;
import net.jqwik.api.*;
import org.junit.jupiter.api.BeforeEach;
import org.mockito.Mock;
import org.mockito.MockitoAnnotations;
import org.redisson.api.RLock;
import org.redisson.api.RedissonClient;
import org.springframework.data.redis.core.RedisTemplate;
import org.springframework.data.redis.core.ValueOperations;

import java.util.concurrent.CountDownLatch;
import java.util.concurrent.TimeUnit;
import java.util.concurrent.atomic.AtomicInteger;

import static org.assertj.core.api.Assertions.assertThat;
import static org.mockito.ArgumentMatchers.*;
import static org.mockito.Mockito.*;

/**
 * Feature: cache-penetration-protection, Property 1: 分布式锁互斥性
 * Validates: Requirements 1.1, 2.1, 3.1
 * 
 * Property: For any entity ID, when multiple concurrent requests query expired cache,
 * only one request should acquire the lock and query the database.
 */
class CachedDualStorageManagerLockMutualExclusionPropertyTest {

    @Mock
    private DualStorageManager delegate;
    
    @Mock
    private RedisTemplate<String, Object> redisTemplate;
    
    @Mock
    private RedissonClient redissonClient;
    
    @Mock
    private HotDataIdentifier hotDataIdentifier;
    
    @Mock
    private ValueOperations<String, Object> valueOperations;
    
    @Mock
    private RLock lock;
    
    private CacheProperties cacheProperties;
    private CachedDualStorageManager cachedManager;

    @BeforeEach
    void setUp() {
        MockitoAnnotations.openMocks(this);
        
        cacheProperties = new CacheProperties();
        cacheProperties.setEntityDetail(600);
        cacheProperties.setLockWaitTime(5);
        cacheProperties.setLockLeaseTime(10);
        cacheProperties.setNullValueTtl(60);
        cacheProperties.setHotDataIdentificationEnabled(true);
        
        cachedManager = new CachedDualStorageManager(
            delegate,
            redisTemplate,
            redissonClient,
            hotDataIdentifier,
            cacheProperties
        );
        
        when(redisTemplate.opsForValue()).thenReturn(valueOperations);
    }

    /**
     * Property 1: 分布式锁互斥性
     * For any entity ID, only one concurrent request should query the database
     */
    @Property(tries = 100)
    void lockMutualExclusion(@ForAll @LongRange(min = 1, max = 10000) Long postId) throws Exception {
        // Given: Cache miss and hot data
        String cacheKey = PostRedisKeys.content(postId);
        String lockKey = PostRedisKeys.lockContent(postId);
        
        when(valueOperations.get(cacheKey)).thenReturn(null);
        when(hotDataIdentifier.isHotData("post", postId)).thenReturn(true);
        when(hotDataIdentifier.isManuallyMarkedAsHot("post", postId)).thenReturn(false);
        when(redissonClient.getLock(lockKey)).thenReturn(lock);
        
        // Mock lock behavior: first thread acquires, others wait
        AtomicInteger lockAcquireCount = new AtomicInteger(0);
        AtomicInteger databaseQueryCount = new AtomicInteger(0);
        
        when(lock.tryLock(anyLong(), anyLong(), any(TimeUnit.class))).thenAnswer(invocation -> {
            int count = lockAcquireCount.incrementAndGet();
            return count == 1; // Only first thread acquires lock
        });
        
        when(lock.isHeldByCurrentThread()).thenAnswer(invocation -> {
            return lockAcquireCount.get() == 1;
        });
        
        PostContent mockContent = new PostContent();
        mockContent.setPostId(postId.toString());
        mockContent.setTitle("Test Post " + postId);
        mockContent.setRaw("Test content");
        
        when(delegate.getPostContent(postId)).thenAnswer(invocation -> {
            databaseQueryCount.incrementAndGet();
            return mockContent;
        });
        
        // When: Multiple concurrent requests (simulate 5 threads)
        int threadCount = 5;
        CountDownLatch startLatch = new CountDownLatch(1);
        CountDownLatch endLatch = new CountDownLatch(threadCount);
        
        for (int i = 0; i < threadCount; i++) {
            new Thread(() -> {
                try {
                    startLatch.await(); // Wait for all threads to be ready
                    cachedManager.getPostContent(postId);
                } catch (Exception e) {
                    // Ignore
                } finally {
                    endLatch.countDown();
                }
            }).start();
        }
        
        startLatch.countDown(); // Start all threads
        endLatch.await(10, TimeUnit.SECONDS); // Wait for completion
        
        // Then: Only one thread should have queried the database
        assertThat(databaseQueryCount.get())
            .as("Only one request should query the database for postId: " + postId)
            .isEqualTo(1);
        
        // Verify lock was attempted by all threads
        verify(lock, atLeast(threadCount)).tryLock(anyLong(), anyLong(), any(TimeUnit.class));
    }
}
