package com.zhicore.content.infrastructure.persistence.mongo.repository;

import com.zhicore.content.infrastructure.persistence.mongo.document.PostContent;
import net.jqwik.api.*;
import net.jqwik.api.constraints.IntRange;
import net.jqwik.api.constraints.StringLength;
import org.junit.jupiter.api.BeforeEach;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.autoconfigure.data.mongo.DataMongoTest;
import org.springframework.test.context.DynamicPropertyRegistry;
import org.springframework.test.context.DynamicPropertySource;
import org.testcontainers.containers.MongoDBContainer;
import org.testcontainers.junit.jupiter.Container;
import org.testcontainers.junit.jupiter.Testcontainers;

import java.time.LocalDateTime;
import java.util.*;

import static org.assertj.core.api.Assertions.assertThat;

/**
 * PostContentRepository Rich Text Block Type Support Property Test
 * 
 * Uses property-based testing to validate that all supported content block types
 * (text, image, video, code, chart) can be correctly stored with their structure
 * and properties.
 * 
 * **Feature: post-mongodb-hybrid, Property 16: 富文本块类型支持**
 * 
 * **Validates: Requirements 5.2**
 * 
 * Property 16: 富文本块类型支持
 * 对于任意支持的内容块类型（文本、图片、视频、代码、图表），
 * 系统都应该能正确存储其结构和属性。
 */
@DataMongoTest
@Testcontainers
class PostContentRepositoryBlockTypePropertyTest {

    @Container
    static MongoDBContainer mongoDBContainer = new MongoDBContainer("mongo:8.0")
            .withExposedPorts(27017);

    @DynamicPropertySource
    static void setProperties(DynamicPropertyRegistry registry) {
        registry.add("spring.data.mongodb.uri", mongoDBContainer::getReplicaSetUrl);
    }

    @Autowired
    private PostContentRepository postContentRepository;

    @BeforeEach
    void setUp() {
        postContentRepository.deleteAll();
    }

    /**
     * Property 16: Text block type storage and retrieval
     * 
     * For any text block with arbitrary content and properties, the system
     * should correctly store and retrieve the block structure.
     * 
     * **Validates: Requirements 5.2**
     */
    @Property(tries = 100)
    @Label("Property 16: Text block type storage and retrieval")
    void textBlockTypeStorageAndRetrieval(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @StringLength(min = 10, max = 1000) String textContent,
            @ForAll @IntRange(min = 0, max = 100) int order) {

        // Given: PostContent with text block
        String postIdStr = String.valueOf(postId);
        Map<String, Object> props = new HashMap<>();
        props.put("fontSize", "16px");
        props.put("color", "#333333");
        props.put("alignment", "left");

        PostContent.ContentBlock textBlock = PostContent.ContentBlock.builder()
                .type("text")
                .content(textContent)
                .props(props)
                .order(order)
                .build();

        PostContent original = PostContent.builder()
                .postId(postIdStr)
                .contentType("rich")
                .raw(textContent)
                .html(textContent)
                .text(textContent)
                .blocks(Collections.singletonList(textBlock))
                .wordCount(textContent.split("\\s+").length)
                .readingTime(1)
                .createdAt(LocalDateTime.now())
                .updatedAt(LocalDateTime.now())
                .build();

        // When: Save and retrieve
        postContentRepository.save(original);
        Optional<PostContent> retrieved = postContentRepository.findByPostId(postIdStr);

        // Then: Text block should be preserved with all properties
        assertThat(retrieved).isPresent();
        PostContent content = retrieved.get();
        assertThat(content.getBlocks()).isNotNull();
        assertThat(content.getBlocks()).hasSize(1);

        PostContent.ContentBlock retrievedBlock = content.getBlocks().get(0);
        assertThat(retrievedBlock.getType()).isEqualTo("text");
        assertThat(retrievedBlock.getContent()).isEqualTo(textContent);
        assertThat(retrievedBlock.getOrder()).isEqualTo(order);
        assertThat(retrievedBlock.getProps()).isNotNull();
    }

    /**
     * Property 16: Image block type storage and retrieval
     * 
     * For any image block with URL and properties, the system should
     * correctly store and retrieve the block structure.
     * 
     * **Validates: Requirements 5.2**
     */
    @Property(tries = 100)
    @Label("Property 16: Image block type storage and retrieval")
    void imageBlockTypeStorageAndRetrieval(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @StringLength(min = 10, max = 200) String imageUrl,
            @ForAll @IntRange(min = 0, max = 100) int order) {

        // Given: PostContent with image block
        String postIdStr = String.valueOf(postId);
        String fullImageUrl = "https://example.com/images/" + imageUrl + ".jpg";
        
        Map<String, Object> props = new HashMap<>();
        props.put("width", 800);
        props.put("height", 600);
        props.put("alt", "Image description");
        props.put("caption", "Image caption");

        PostContent.ContentBlock imageBlock = PostContent.ContentBlock.builder()
                .type("image")
                .content(fullImageUrl)
                .props(props)
                .order(order)
                .build();

        PostContent original = PostContent.builder()
                .postId(postIdStr)
                .contentType("rich")
                .raw(fullImageUrl)
                .html("<img src=\"" + fullImageUrl + "\">")
                .text("")
                .blocks(Collections.singletonList(imageBlock))
                .wordCount(0)
                .readingTime(1)
                .createdAt(LocalDateTime.now())
                .updatedAt(LocalDateTime.now())
                .build();

        // When: Save and retrieve
        postContentRepository.save(original);
        Optional<PostContent> retrieved = postContentRepository.findByPostId(postIdStr);

        // Then: Image block should be preserved with all properties
        assertThat(retrieved).isPresent();
        PostContent content = retrieved.get();
        assertThat(content.getBlocks()).isNotNull();
        assertThat(content.getBlocks()).hasSize(1);

        PostContent.ContentBlock retrievedBlock = content.getBlocks().get(0);
        assertThat(retrievedBlock.getType()).isEqualTo("image");
        assertThat(retrievedBlock.getContent()).isEqualTo(fullImageUrl);
        assertThat(retrievedBlock.getOrder()).isEqualTo(order);
        assertThat(retrievedBlock.getProps()).isNotNull();
    }

    /**
     * Property 16: Video block type storage and retrieval
     * 
     * For any video block with URL and properties, the system should
     * correctly store and retrieve the block structure.
     * 
     * **Validates: Requirements 5.2**
     */
    @Property(tries = 100)
    @Label("Property 16: Video block type storage and retrieval")
    void videoBlockTypeStorageAndRetrieval(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @StringLength(min = 10, max = 200) String videoUrl,
            @ForAll @IntRange(min = 0, max = 100) int order) {

        // Given: PostContent with video block
        String postIdStr = String.valueOf(postId);
        String fullVideoUrl = "https://example.com/videos/" + videoUrl + ".mp4";
        
        Map<String, Object> props = new HashMap<>();
        props.put("width", 1920);
        props.put("height", 1080);
        props.put("duration", 120);
        props.put("autoplay", false);
        props.put("controls", true);

        PostContent.ContentBlock videoBlock = PostContent.ContentBlock.builder()
                .type("video")
                .content(fullVideoUrl)
                .props(props)
                .order(order)
                .build();

        PostContent original = PostContent.builder()
                .postId(postIdStr)
                .contentType("rich")
                .raw(fullVideoUrl)
                .html("<video src=\"" + fullVideoUrl + "\"></video>")
                .text("")
                .blocks(Collections.singletonList(videoBlock))
                .wordCount(0)
                .readingTime(1)
                .createdAt(LocalDateTime.now())
                .updatedAt(LocalDateTime.now())
                .build();

        // When: Save and retrieve
        postContentRepository.save(original);
        Optional<PostContent> retrieved = postContentRepository.findByPostId(postIdStr);

        // Then: Video block should be preserved with all properties
        assertThat(retrieved).isPresent();
        PostContent content = retrieved.get();
        assertThat(content.getBlocks()).isNotNull();
        assertThat(content.getBlocks()).hasSize(1);

        PostContent.ContentBlock retrievedBlock = content.getBlocks().get(0);
        assertThat(retrievedBlock.getType()).isEqualTo("video");
        assertThat(retrievedBlock.getContent()).isEqualTo(fullVideoUrl);
        assertThat(retrievedBlock.getOrder()).isEqualTo(order);
        assertThat(retrievedBlock.getProps()).isNotNull();
    }

    /**
     * Property 16: Code block type storage and retrieval
     * 
     * For any code block with source code and properties, the system should
     * correctly store and retrieve the block structure.
     * 
     * **Validates: Requirements 5.2**
     */
    @Property(tries = 100)
    @Label("Property 16: Code block type storage and retrieval")
    void codeBlockTypeStorageAndRetrieval(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @StringLength(min = 10, max = 1000) String codeContent,
            @ForAll("programmingLanguage") String language,
            @ForAll @IntRange(min = 0, max = 100) int order) {

        // Given: PostContent with code block
        String postIdStr = String.valueOf(postId);
        
        Map<String, Object> props = new HashMap<>();
        props.put("language", language);
        props.put("lineNumbers", true);
        props.put("theme", "monokai");
        props.put("highlightLines", Arrays.asList(1, 5, 10));

        PostContent.ContentBlock codeBlock = PostContent.ContentBlock.builder()
                .type("code")
                .content(codeContent)
                .props(props)
                .order(order)
                .build();

        PostContent original = PostContent.builder()
                .postId(postIdStr)
                .contentType("rich")
                .raw(codeContent)
                .html("<pre><code>" + codeContent + "</code></pre>")
                .text(codeContent)
                .blocks(Collections.singletonList(codeBlock))
                .wordCount(codeContent.split("\\s+").length)
                .readingTime(1)
                .createdAt(LocalDateTime.now())
                .updatedAt(LocalDateTime.now())
                .build();

        // When: Save and retrieve
        postContentRepository.save(original);
        Optional<PostContent> retrieved = postContentRepository.findByPostId(postIdStr);

        // Then: Code block should be preserved with all properties
        assertThat(retrieved).isPresent();
        PostContent content = retrieved.get();
        assertThat(content.getBlocks()).isNotNull();
        assertThat(content.getBlocks()).hasSize(1);

        PostContent.ContentBlock retrievedBlock = content.getBlocks().get(0);
        assertThat(retrievedBlock.getType()).isEqualTo("code");
        assertThat(retrievedBlock.getContent()).isEqualTo(codeContent);
        assertThat(retrievedBlock.getOrder()).isEqualTo(order);
        assertThat(retrievedBlock.getProps()).isNotNull();
    }

    /**
     * Property 16: Chart block type storage and retrieval
     * 
     * For any chart block with data and properties, the system should
     * correctly store and retrieve the block structure.
     * 
     * **Validates: Requirements 5.2**
     */
    @Property(tries = 100)
    @Label("Property 16: Chart block type storage and retrieval")
    void chartBlockTypeStorageAndRetrieval(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @StringLength(min = 10, max = 500) String chartData,
            @ForAll("chartType") String chartType,
            @ForAll @IntRange(min = 0, max = 100) int order) {

        // Given: PostContent with chart block
        String postIdStr = String.valueOf(postId);
        
        Map<String, Object> props = new HashMap<>();
        props.put("chartType", chartType);
        props.put("width", 600);
        props.put("height", 400);
        props.put("title", "Chart Title");
        props.put("xAxisLabel", "X Axis");
        props.put("yAxisLabel", "Y Axis");

        PostContent.ContentBlock chartBlock = PostContent.ContentBlock.builder()
                .type("chart")
                .content(chartData)
                .props(props)
                .order(order)
                .build();

        PostContent original = PostContent.builder()
                .postId(postIdStr)
                .contentType("rich")
                .raw(chartData)
                .html("<div class=\"chart\">" + chartData + "</div>")
                .text("")
                .blocks(Collections.singletonList(chartBlock))
                .wordCount(0)
                .readingTime(1)
                .createdAt(LocalDateTime.now())
                .updatedAt(LocalDateTime.now())
                .build();

        // When: Save and retrieve
        postContentRepository.save(original);
        Optional<PostContent> retrieved = postContentRepository.findByPostId(postIdStr);

        // Then: Chart block should be preserved with all properties
        assertThat(retrieved).isPresent();
        PostContent content = retrieved.get();
        assertThat(content.getBlocks()).isNotNull();
        assertThat(content.getBlocks()).hasSize(1);

        PostContent.ContentBlock retrievedBlock = content.getBlocks().get(0);
        assertThat(retrievedBlock.getType()).isEqualTo("chart");
        assertThat(retrievedBlock.getContent()).isEqualTo(chartData);
        assertThat(retrievedBlock.getOrder()).isEqualTo(order);
        assertThat(retrievedBlock.getProps()).isNotNull();
    }

    /**
     * Property 16: Multiple block types coexistence
     * 
     * For any combination of different block types, the system should
     * correctly store and retrieve all blocks in order.
     * 
     * **Validates: Requirements 5.2**
     */
    @Property(tries = 100)
    @Label("Property 16: Multiple block types coexistence")
    void multipleBlockTypesCoexistence(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll("mixedBlockList") List<PostContent.ContentBlock> blocks) {

        // Given: PostContent with multiple different block types
        String postIdStr = String.valueOf(postId);
        String combinedText = blocks.stream()
                .filter(b -> "text".equals(b.getType()) || "code".equals(b.getType()))
                .map(PostContent.ContentBlock::getContent)
                .reduce("", (a, b) -> a + " " + b);

        PostContent original = PostContent.builder()
                .postId(postIdStr)
                .contentType("rich")
                .raw(combinedText)
                .html(combinedText)
                .text(combinedText)
                .blocks(blocks)
                .wordCount(combinedText.isEmpty() ? 0 : combinedText.split("\\s+").length)
                .readingTime(1)
                .createdAt(LocalDateTime.now())
                .updatedAt(LocalDateTime.now())
                .build();

        // When: Save and retrieve
        postContentRepository.save(original);
        Optional<PostContent> retrieved = postContentRepository.findByPostId(postIdStr);

        // Then: All blocks should be preserved in order
        assertThat(retrieved).isPresent();
        PostContent content = retrieved.get();
        assertThat(content.getBlocks()).isNotNull();
        assertThat(content.getBlocks()).hasSize(blocks.size());

        // Verify each block type is preserved
        for (int i = 0; i < blocks.size(); i++) {
            PostContent.ContentBlock originalBlock = blocks.get(i);
            PostContent.ContentBlock retrievedBlock = content.getBlocks().get(i);
            
            assertThat(retrievedBlock.getType()).isEqualTo(originalBlock.getType());
            assertThat(retrievedBlock.getContent()).isEqualTo(originalBlock.getContent());
            assertThat(retrievedBlock.getOrder()).isEqualTo(originalBlock.getOrder());
            assertThat(retrievedBlock.getProps()).isNotNull();
        }
    }

    /**
     * Property 16: Block ordering preservation
     * 
     * For any list of blocks with different order values, the system should
     * preserve the order exactly as stored.
     * 
     * **Validates: Requirements 5.2**
     */
    @Property(tries = 100)
    @Label("Property 16: Block ordering preservation")
    void blockOrderingPreservation(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll("orderedBlockList") List<PostContent.ContentBlock> blocks) {

        // Given: PostContent with blocks in specific order
        String postIdStr = String.valueOf(postId);

        PostContent original = PostContent.builder()
                .postId(postIdStr)
                .contentType("rich")
                .raw("content")
                .html("content")
                .text("content")
                .blocks(blocks)
                .wordCount(1)
                .readingTime(1)
                .createdAt(LocalDateTime.now())
                .updatedAt(LocalDateTime.now())
                .build();

        // When: Save and retrieve
        postContentRepository.save(original);
        Optional<PostContent> retrieved = postContentRepository.findByPostId(postIdStr);

        // Then: Block order should be preserved exactly
        assertThat(retrieved).isPresent();
        PostContent content = retrieved.get();
        assertThat(content.getBlocks()).isNotNull();
        assertThat(content.getBlocks()).hasSize(blocks.size());

        // Verify order is preserved
        for (int i = 0; i < blocks.size(); i++) {
            assertThat(content.getBlocks().get(i).getOrder())
                    .isEqualTo(blocks.get(i).getOrder());
        }
    }

    /**
     * Property 16: Block properties preservation
     * 
     * For any block with complex properties (nested objects, arrays),
     * the system should preserve all property structures.
     * 
     * **Validates: Requirements 5.2**
     */
    @Property(tries = 100)
    @Label("Property 16: Block properties preservation")
    void blockPropertiesPreservation(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll("blockWithComplexProps") PostContent.ContentBlock block) {

        // Given: PostContent with block containing complex properties
        String postIdStr = String.valueOf(postId);

        PostContent original = PostContent.builder()
                .postId(postIdStr)
                .contentType("rich")
                .raw(block.getContent())
                .html(block.getContent())
                .text(block.getContent())
                .blocks(Collections.singletonList(block))
                .wordCount(1)
                .readingTime(1)
                .createdAt(LocalDateTime.now())
                .updatedAt(LocalDateTime.now())
                .build();

        // When: Save and retrieve
        postContentRepository.save(original);
        Optional<PostContent> retrieved = postContentRepository.findByPostId(postIdStr);

        // Then: Complex properties should be preserved
        assertThat(retrieved).isPresent();
        PostContent content = retrieved.get();
        assertThat(content.getBlocks()).isNotNull();
        assertThat(content.getBlocks()).hasSize(1);

        PostContent.ContentBlock retrievedBlock = content.getBlocks().get(0);
        assertThat(retrievedBlock.getType()).isEqualTo(block.getType());
        assertThat(retrievedBlock.getContent()).isEqualTo(block.getContent());
        assertThat(retrievedBlock.getProps()).isNotNull();
        
        // Verify props is a Map and has content
        if (retrievedBlock.getProps() instanceof Map) {
            Map<?, ?> propsMap = (Map<?, ?>) retrievedBlock.getProps();
            assertThat(propsMap).isNotEmpty();
        }
    }

    /**
     * Property 16: Empty blocks handling
     * 
     * For any block type with empty content, the system should
     * handle it gracefully and preserve the block structure.
     * 
     * **Validates: Requirements 5.2**
     */
    @Property(tries = 100)
    @Label("Property 16: Empty blocks handling")
    void emptyBlocksHandling(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll("blockType") String blockType,
            @ForAll @IntRange(min = 0, max = 100) int order) {

        // Given: PostContent with empty block
        String postIdStr = String.valueOf(postId);

        PostContent.ContentBlock emptyBlock = PostContent.ContentBlock.builder()
                .type(blockType)
                .content("")
                .props(new HashMap<>())
                .order(order)
                .build();

        PostContent original = PostContent.builder()
                .postId(postIdStr)
                .contentType("rich")
                .raw("")
                .html("")
                .text("")
                .blocks(Collections.singletonList(emptyBlock))
                .wordCount(0)
                .readingTime(0)
                .createdAt(LocalDateTime.now())
                .updatedAt(LocalDateTime.now())
                .build();

        // When: Save and retrieve
        postContentRepository.save(original);
        Optional<PostContent> retrieved = postContentRepository.findByPostId(postIdStr);

        // Then: Empty block should be preserved
        assertThat(retrieved).isPresent();
        PostContent content = retrieved.get();
        assertThat(content.getBlocks()).isNotNull();
        assertThat(content.getBlocks()).hasSize(1);

        PostContent.ContentBlock retrievedBlock = content.getBlocks().get(0);
        assertThat(retrievedBlock.getType()).isEqualTo(blockType);
        assertThat(retrievedBlock.getContent()).isEmpty();
        assertThat(retrievedBlock.getOrder()).isEqualTo(order);
    }

    // Data generators

    @Provide
    Arbitrary<String> blockType() {
        return Arbitraries.of("text", "image", "video", "code", "chart");
    }

    @Provide
    Arbitrary<String> programmingLanguage() {
        return Arbitraries.of("java", "python", "javascript", "typescript", "go", "rust", "c++");
    }

    @Provide
    Arbitrary<String> chartType() {
        return Arbitraries.of("line", "bar", "pie", "scatter", "area");
    }

    @Provide
    Arbitrary<PostContent.ContentBlock> mixedBlock() {
        return Combinators.combine(
                blockType(),
                Arbitraries.strings().alpha().ofMinLength(5).ofMaxLength(200),
                Arbitraries.integers().between(0, 100)
        ).as((type, content, order) -> {
            Map<String, Object> props = new HashMap<>();
            props.put("key1", "value1");
            props.put("key2", 123);
            
            return PostContent.ContentBlock.builder()
                    .type(type)
                    .content(content)
                    .props(props)
                    .order(order)
                    .build();
        });
    }

    @Provide
    Arbitrary<List<PostContent.ContentBlock>> mixedBlockList() {
        return mixedBlock()
                .list()
                .ofMinSize(2)
                .ofMaxSize(5);
    }

    @Provide
    Arbitrary<List<PostContent.ContentBlock>> orderedBlockList() {
        return Combinators.combine(
                blockType().list().ofMinSize(3).ofMaxSize(5),
                Arbitraries.integers().between(0, 100).list().ofMinSize(3).ofMaxSize(5)
        ).as((types, orders) -> {
            List<PostContent.ContentBlock> blocks = new ArrayList<>();
            int size = Math.min(types.size(), orders.size());
            
            for (int i = 0; i < size; i++) {
                blocks.add(PostContent.ContentBlock.builder()
                        .type(types.get(i))
                        .content("Content " + i)
                        .props(new HashMap<>())
                        .order(orders.get(i))
                        .build());
            }
            
            return blocks;
        });
    }

    @Provide
    Arbitrary<PostContent.ContentBlock> blockWithComplexProps() {
        return Combinators.combine(
                blockType(),
                Arbitraries.strings().alpha().ofMinLength(10).ofMaxLength(200),
                Arbitraries.integers().between(0, 100)
        ).as((type, content, order) -> {
            Map<String, Object> props = new HashMap<>();
            props.put("stringProp", "value");
            props.put("intProp", 42);
            props.put("boolProp", true);
            props.put("arrayProp", Arrays.asList("item1", "item2", "item3"));
            
            Map<String, Object> nestedMap = new HashMap<>();
            nestedMap.put("nested1", "nestedValue1");
            nestedMap.put("nested2", 100);
            props.put("nestedProp", nestedMap);
            
            return PostContent.ContentBlock.builder()
                    .type(type)
                    .content(content)
                    .props(props)
                    .order(order)
                    .build();
        });
    }
}

