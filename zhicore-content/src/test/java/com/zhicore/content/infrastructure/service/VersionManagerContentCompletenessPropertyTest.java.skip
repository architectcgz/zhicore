package com.zhicore.post.infrastructure.service;

import service.domain.com.zhicore.content.VersionManager;
import document.mongodb.infrastructure.com.zhicore.content.PostContent;
import document.mongodb.infrastructure.com.zhicore.content.PostVersion;
import repository.mongodb.infrastructure.com.zhicore.content.PostContentRepository;
import repository.mongodb.infrastructure.com.zhicore.content.PostVersionRepository;
import net.jqwik.api.*;
import net.jqwik.api.constraints.IntRange;
import net.jqwik.api.constraints.StringLength;
import org.junit.jupiter.api.BeforeEach;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.context.SpringBootTest;
import org.springframework.test.context.DynamicPropertyRegistry;
import org.springframework.test.context.DynamicPropertySource;
import org.testcontainers.containers.MongoDBContainer;
import org.testcontainers.junit.jupiter.Container;
import org.testcontainers.junit.jupiter.Testcontainers;

import java.time.LocalDateTime;
import java.util.Optional;

import static org.assertj.core.api.Assertions.assertThat;

/**
 * Version Manager Content Completeness Property Test
 * 
 * Uses property-based testing to validate that version content and metadata
 * are complete and preserved when querying specific versions.
 * 
 * **Feature: post-mongodb-hybrid, Property 8: 版本内容完整性**
 * 
 * **Validates: Requirements 3.3, 3.6**
 * 
 * Property 8: 版本内容完整性
 * 对于任意有效的版本号，查询该版本应该返回完整的内容快照，
 * 包括内容本身和所有元数据（版本号、编辑者、编辑时间、变更说明）。
 */
@SpringBootTest
@Testcontainers
class VersionManagerContentCompletenessPropertyTest {

    @Container
    static MongoDBContainer mongoDBContainer = new MongoDBContainer("mongo:8.0")
            .withExposedPorts(27017);

    @DynamicPropertySource
    static void setProperties(DynamicPropertyRegistry registry) {
        registry.add("spring.data.mongodb.uri", mongoDBContainer::getReplicaSetUrl);
    }

    @Autowired
    private VersionManager versionManager;

    @Autowired
    private PostVersionRepository versionRepository;

    @Autowired
    private PostContentRepository contentRepository;

    @BeforeEach
    void setUp() {
        versionRepository.deleteAll();
        contentRepository.deleteAll();
    }

    /**
     * Property 8: Version query returns complete content snapshot
     * 
     * For any valid version number, querying that version should return
     * the complete content snapshot including all metadata fields.
     * 
     * **Validates: Requirements 3.3, 3.6**
     */
    @Property(tries = 100)
    @Label("Property 8: Version query returns complete content snapshot")
    void versionQueryReturnsCompleteContentSnapshot(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @IntRange(min = 1, max = 100000) long ownerId,
            @ForAll @StringLength(min = 10, max = 500) String content,
            @ForAll @StringLength(min = 5, max = 200) String changeNote) {

        // Given: A post with initial content
        String postIdStr = String.valueOf(postId);
        String ownerIdStr = String.valueOf(ownerId);

        // Create initial content in MongoDB
        PostContent initialContent = PostContent.builder()
                .postId(postIdStr)
                .contentType("markdown")
                .raw(content)
                .html("<p>" + content + "</p>")
                .text(content)
                .createdAt(LocalDateTime.now())
                .updatedAt(LocalDateTime.now())
                .build();
        contentRepository.save(initialContent);

        // When: Create a version
        Integer versionNumber = versionManager.createVersion(
                postIdStr,
                content,
                ownerIdStr,
                changeNote
        );

        // Then: Query the version and verify all fields are present and complete
        Optional<PostVersion> versionOpt = versionManager.getVersion(postIdStr, versionNumber);

        assertThat(versionOpt).isPresent();

        PostVersion version = versionOpt.get();

        // Verify all required fields are present and not null
        assertThat(version.getId())
                .as("Version ID should not be null")
                .isNotNull();

        assertThat(version.getPostId())
                .as("Post ID should match")
                .isEqualTo(postIdStr);

        assertThat(version.getVersion())
                .as("Version number should match")
                .isEqualTo(versionNumber);

        assertThat(version.getContent())
                .as("Content should be present and match")
                .isNotNull()
                .isEqualTo(content);

        assertThat(version.getContentType())
                .as("Content type should be present")
                .isNotNull()
                .isNotEmpty();

        assertThat(version.getEditedBy())
                .as("Editor ID should match")
                .isEqualTo(ownerIdStr);

        assertThat(version.getEditedAt())
                .as("Edit timestamp should be present")
                .isNotNull()
                .isBefore(LocalDateTime.now().plusSeconds(1));

        assertThat(version.getChangeNote())
                .as("Change note should match")
                .isEqualTo(changeNote);
    }

    /**
     * Property 8: Multiple versions preserve complete metadata independently
     * 
     * For any post with multiple versions, each version should preserve
     * its own complete metadata independently of other versions.
     * 
     * **Validates: Requirements 3.3, 3.6**
     */
    @Property(tries = 100)
    @Label("Property 8: Multiple versions preserve complete metadata independently")
    void multipleVersionsPreserveCompleteMetadataIndependently(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll("versionDataList") java.util.List<VersionData> versionDataList) {

        // Given: A post with initial content
        String postIdStr = String.valueOf(postId);

        // Create initial content in MongoDB
        PostContent initialContent = PostContent.builder()
                .postId(postIdStr)
                .contentType("markdown")
                .raw("Initial content")
                .html("<p>Initial content</p>")
                .text("Initial content")
                .createdAt(LocalDateTime.now())
                .updatedAt(LocalDateTime.now())
                .build();
        contentRepository.save(initialContent);

        // When: Create multiple versions with different metadata
        for (VersionData versionData : versionDataList) {
            versionManager.createVersion(
                    postIdStr,
                    versionData.content,
                    versionData.editorId,
                    versionData.changeNote
            );
        }

        // Then: Each version should preserve its complete metadata
        for (int i = 0; i < versionDataList.size(); i++) {
            int versionNumber = i + 1;
            VersionData expectedData = versionDataList.get(i);

            Optional<PostVersion> versionOpt = versionManager.getVersion(postIdStr, versionNumber);

            assertThat(versionOpt)
                    .as("Version %d should exist", versionNumber)
                    .isPresent();

            PostVersion version = versionOpt.get();

            // Verify all metadata fields match the expected data
            assertThat(version.getPostId()).isEqualTo(postIdStr);
            assertThat(version.getVersion()).isEqualTo(versionNumber);
            assertThat(version.getContent()).isEqualTo(expectedData.content);
            assertThat(version.getEditedBy()).isEqualTo(expectedData.editorId);
            assertThat(version.getChangeNote()).isEqualTo(expectedData.changeNote);
            assertThat(version.getContentType()).isNotNull();
            assertThat(version.getEditedAt()).isNotNull();
        }
    }

    /**
     * Property 8: Version content is immutable after creation
     * 
     * For any version, querying it multiple times should always return
     * the same complete content and metadata.
     * 
     * **Validates: Requirements 3.3, 3.6**
     */
    @Property(tries = 100)
    @Label("Property 8: Version content is immutable after creation")
    void versionContentIsImmutableAfterCreation(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @IntRange(min = 1, max = 100000) long ownerId,
            @ForAll @StringLength(min = 10, max = 500) String content,
            @ForAll @StringLength(min = 5, max = 200) String changeNote,
            @ForAll @IntRange(min = 2, max = 5) int queryCount) {

        // Given: A post with a version
        String postIdStr = String.valueOf(postId);
        String ownerIdStr = String.valueOf(ownerId);

        // Create initial content in MongoDB
        PostContent initialContent = PostContent.builder()
                .postId(postIdStr)
                .contentType("markdown")
                .raw(content)
                .html("<p>" + content + "</p>")
                .text(content)
                .createdAt(LocalDateTime.now())
                .updatedAt(LocalDateTime.now())
                .build();
        contentRepository.save(initialContent);

        Integer versionNumber = versionManager.createVersion(
                postIdStr,
                content,
                ownerIdStr,
                changeNote
        );

        // When: Query the version multiple times
        PostVersion firstQuery = versionManager.getVersion(postIdStr, versionNumber)
                .orElseThrow(() -> new AssertionError("Version should exist"));

        // Then: All subsequent queries should return identical data
        for (int i = 0; i < queryCount; i++) {
            PostVersion subsequentQuery = versionManager.getVersion(postIdStr, versionNumber)
                    .orElseThrow(() -> new AssertionError("Version should exist on query " + i));

            assertThat(subsequentQuery.getPostId()).isEqualTo(firstQuery.getPostId());
            assertThat(subsequentQuery.getVersion()).isEqualTo(firstQuery.getVersion());
            assertThat(subsequentQuery.getContent()).isEqualTo(firstQuery.getContent());
            assertThat(subsequentQuery.getContentType()).isEqualTo(firstQuery.getContentType());
            assertThat(subsequentQuery.getEditedBy()).isEqualTo(firstQuery.getEditedBy());
            assertThat(subsequentQuery.getChangeNote()).isEqualTo(firstQuery.getChangeNote());
            assertThat(subsequentQuery.getEditedAt()).isEqualTo(firstQuery.getEditedAt());
        }
    }

    /**
     * Property 8: Non-existent version returns empty
     * 
     * For any post, querying a non-existent version number should return
     * an empty Optional, not throw an exception or return incomplete data.
     * 
     * **Validates: Requirements 3.3, 3.6**
     */
    @Property(tries = 100)
    @Label("Property 8: Non-existent version returns empty")
    void nonExistentVersionReturnsEmpty(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @IntRange(min = 1, max = 100000) long ownerId,
            @ForAll @StringLength(min = 10, max = 500) String content,
            @ForAll @IntRange(min = 1, max = 10) int existingVersionCount,
            @ForAll @IntRange(min = 100, max = 1000) int nonExistentVersion) {

        // Given: A post with a known number of versions
        String postIdStr = String.valueOf(postId);
        String ownerIdStr = String.valueOf(ownerId);

        // Create initial content in MongoDB
        PostContent initialContent = PostContent.builder()
                .postId(postIdStr)
                .contentType("markdown")
                .raw(content)
                .html("<p>" + content + "</p>")
                .text(content)
                .createdAt(LocalDateTime.now())
                .updatedAt(LocalDateTime.now())
                .build();
        contentRepository.save(initialContent);

        // Create versions
        for (int i = 0; i < existingVersionCount; i++) {
            versionManager.createVersion(
                    postIdStr,
                    content + " v" + (i + 1),
                    ownerIdStr,
                    "Change " + (i + 1)
            );
        }

        // When: Query a non-existent version number
        Optional<PostVersion> versionOpt = versionManager.getVersion(postIdStr, nonExistentVersion);

        // Then: Should return empty Optional
        assertThat(versionOpt)
                .as("Non-existent version %d should return empty", nonExistentVersion)
                .isEmpty();
    }

    /**
     * Property 8: Version metadata includes all required fields
     * 
     * For any version, all required metadata fields (version number, editor,
     * timestamp, change note) should be present and valid.
     * 
     * **Validates: Requirements 3.3, 3.6**
     */
    @Property(tries = 100)
    @Label("Property 8: Version metadata includes all required fields")
    void versionMetadataIncludesAllRequiredFields(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @IntRange(min = 1, max = 100000) long ownerId,
            @ForAll @StringLength(min = 10, max = 500) String content,
            @ForAll @StringLength(min = 1, max = 200) String changeNote) {

        // Given: A post with initial content
        String postIdStr = String.valueOf(postId);
        String ownerIdStr = String.valueOf(ownerId);

        // Create initial content in MongoDB
        PostContent initialContent = PostContent.builder()
                .postId(postIdStr)
                .contentType("markdown")
                .raw(content)
                .html("<p>" + content + "</p>")
                .text(content)
                .createdAt(LocalDateTime.now())
                .updatedAt(LocalDateTime.now())
                .build();
        contentRepository.save(initialContent);

        LocalDateTime beforeCreation = LocalDateTime.now();

        // When: Create a version
        Integer versionNumber = versionManager.createVersion(
                postIdStr,
                content,
                ownerIdStr,
                changeNote
        );

        LocalDateTime afterCreation = LocalDateTime.now();

        // Then: Query and verify all required fields
        PostVersion version = versionManager.getVersion(postIdStr, versionNumber)
                .orElseThrow(() -> new AssertionError("Version should exist"));

        // Verify version number is valid
        assertThat(version.getVersion())
                .as("Version number should be positive")
                .isPositive()
                .isEqualTo(versionNumber);

        // Verify editor ID is present and matches
        assertThat(version.getEditedBy())
                .as("Editor ID should be present")
                .isNotNull()
                .isNotEmpty()
                .isEqualTo(ownerIdStr);

        // Verify timestamp is within reasonable range
        assertThat(version.getEditedAt())
                .as("Edit timestamp should be between creation time bounds")
                .isNotNull()
                .isAfterOrEqualTo(beforeCreation.minusSeconds(1))
                .isBeforeOrEqualTo(afterCreation.plusSeconds(1));

        // Verify change note is present and matches
        assertThat(version.getChangeNote())
                .as("Change note should be present")
                .isNotNull()
                .isEqualTo(changeNote);

        // Verify content is present
        assertThat(version.getContent())
                .as("Content should be present")
                .isNotNull()
                .isNotEmpty()
                .isEqualTo(content);

        // Verify content type is present
        assertThat(version.getContentType())
                .as("Content type should be present")
                .isNotNull()
                .isNotEmpty();
    }

    /**
     * Property 8: Version content preserves exact content
     * 
     * For any content (including special characters, whitespace, etc.),
     * the version should preserve the exact content without modification.
     * 
     * **Validates: Requirements 3.3, 3.6**
     */
    @Property(tries = 100)
    @Label("Property 8: Version content preserves exact content")
    void versionContentPreservesExactContent(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @IntRange(min = 1, max = 100000) long ownerId,
            @ForAll("specialContent") String specialContent,
            @ForAll @StringLength(min = 5, max = 100) String changeNote) {

        // Given: A post with initial content
        String postIdStr = String.valueOf(postId);
        String ownerIdStr = String.valueOf(ownerId);

        // Create initial content in MongoDB
        PostContent initialContent = PostContent.builder()
                .postId(postIdStr)
                .contentType("markdown")
                .raw(specialContent)
                .html("<p>" + specialContent + "</p>")
                .text(specialContent)
                .createdAt(LocalDateTime.now())
                .updatedAt(LocalDateTime.now())
                .build();
        contentRepository.save(initialContent);

        // When: Create a version with special content
        Integer versionNumber = versionManager.createVersion(
                postIdStr,
                specialContent,
                ownerIdStr,
                changeNote
        );

        // Then: Retrieved content should match exactly
        PostVersion version = versionManager.getVersion(postIdStr, versionNumber)
                .orElseThrow(() -> new AssertionError("Version should exist"));

        assertThat(version.getContent())
                .as("Content should be preserved exactly")
                .isEqualTo(specialContent);

        // Verify content length is preserved
        assertThat(version.getContent().length())
                .as("Content length should match")
                .isEqualTo(specialContent.length());
    }

    /**
     * Property 8: Empty change note is preserved
     * 
     * For any version, even if the change note is empty or minimal,
     * it should be preserved as-is in the version metadata.
     * 
     * **Validates: Requirements 3.3, 3.6**
     */
    @Property(tries = 100)
    @Label("Property 8: Empty change note is preserved")
    void emptyChangeNoteIsPreserved(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @IntRange(min = 1, max = 100000) long ownerId,
            @ForAll @StringLength(min = 10, max = 500) String content,
            @ForAll @StringLength(min = 0, max = 5) String minimalChangeNote) {

        // Given: A post with initial content
        String postIdStr = String.valueOf(postId);
        String ownerIdStr = String.valueOf(ownerId);

        // Create initial content in MongoDB
        PostContent initialContent = PostContent.builder()
                .postId(postIdStr)
                .contentType("markdown")
                .raw(content)
                .html("<p>" + content + "</p>")
                .text(content)
                .createdAt(LocalDateTime.now())
                .updatedAt(LocalDateTime.now())
                .build();
        contentRepository.save(initialContent);

        // When: Create a version with minimal/empty change note
        Integer versionNumber = versionManager.createVersion(
                postIdStr,
                content,
                ownerIdStr,
                minimalChangeNote
        );

        // Then: Change note should be preserved exactly
        PostVersion version = versionManager.getVersion(postIdStr, versionNumber)
                .orElseThrow(() -> new AssertionError("Version should exist"));

        assertThat(version.getChangeNote())
                .as("Change note should be preserved exactly")
                .isEqualTo(minimalChangeNote);
    }

    // Data generators

    /**
     * Generate version data with varied metadata
     */
    @Provide
    Arbitrary<java.util.List<VersionData>> versionDataList() {
        Arbitrary<String> content = Arbitraries.strings()
                .alpha()
                .numeric()
                .ofMinLength(10)
                .ofMaxLength(500);

        Arbitrary<String> editorId = Arbitraries.longs()
                .between(1, 100000)
                .map(String::valueOf);

        Arbitrary<String> changeNote = Arbitraries.strings()
                .alpha()
                .ofMinLength(5)
                .ofMaxLength(200);

        return Combinators.combine(content, editorId, changeNote)
                .as(VersionData::new)
                .list()
                .ofMinSize(1)
                .ofMaxSize(10);
    }

    /**
     * Generate content with special characters and whitespace
     */
    @Provide
    Arbitrary<String> specialContent() {
        return Arbitraries.strings()
                .withCharRange('!', '~')
                .ofMinLength(10)
                .ofMaxLength(500);
    }

    /**
     * Helper class to hold version data
     */
    private static class VersionData {
        final String content;
        final String editorId;
        final String changeNote;

        VersionData(String content, String editorId, String changeNote) {
            this.content = content;
            this.editorId = editorId;
            this.changeNote = changeNote;
        }
    }
}
