package com.zhicore.post.infrastructure.service;

import com.zhicore.common.cache.HotDataIdentifier;
import com.zhicore.common.config.CacheProperties;
import com.zhicore.post.domain.model.PostContent;
import cache.infrastructure.com.zhicore.content.PostRedisKeys;
import net.jqwik.api.*;
import org.junit.jupiter.api.BeforeEach;
import org.mockito.Mock;
import org.mockito.MockitoAnnotations;
import org.redisson.api.RLock;
import org.redisson.api.RedissonClient;
import org.springframework.data.redis.core.RedisTemplate;
import org.springframework.data.redis.core.ValueOperations;

import java.util.concurrent.TimeUnit;

import static org.assertj.core.api.Assertions.assertThat;
import static org.mockito.ArgumentMatchers.*;
import static org.mockito.Mockito.*;

/**
 * Feature: cache-penetration-protection, Property 2: 双重检查锁（DCL）正确性
 * Validates: Requirements 1.2, 2.2, 3.2
 * 
 * Property: For any entity ID, when lock is acquired but cache is already filled,
 * should not query database again (DCL prevents redundant queries).
 */
class CachedDualStorageManagerDCLPropertyTest {

    @Mock
    private DualStorageManager delegate;
    
    @Mock
    private RedisTemplate<String, Object> redisTemplate;
    
    @Mock
    private RedissonClient redissonClient;
    
    @Mock
    private HotDataIdentifier hotDataIdentifier;
    
    @Mock
    private ValueOperations<String, Object> valueOperations;
    
    @Mock
    private RLock lock;
    
    private CacheProperties cacheProperties;
    private CachedDualStorageManager cachedManager;

    @BeforeEach
    void setUp() {
        MockitoAnnotations.openMocks(this);
        
        cacheProperties = new CacheProperties();
        cacheProperties.setEntityDetail(600);
        cacheProperties.setLockWaitTime(5);
        cacheProperties.setLockLeaseTime(10);
        cacheProperties.setNullValueTtl(60);
        cacheProperties.setHotDataIdentificationEnabled(true);
        
        cachedManager = new CachedDualStorageManager(
            delegate,
            redisTemplate,
            redissonClient,
            hotDataIdentifier,
            cacheProperties
        );
        
        when(redisTemplate.opsForValue()).thenReturn(valueOperations);
    }

    /**
     * Property 2: 双重检查锁（DCL）正确性
     * For any entity ID, DCL should prevent redundant database queries
     */
    @Property(tries = 100)
    void dclPreventsRedundantQueries(@ForAll @LongRange(min = 1, max = 10000) Long postId) throws Exception {
        // Given: Cache miss on first check, but filled before lock acquisition
        String cacheKey = PostRedisKeys.content(postId);
        String lockKey = PostRedisKeys.lockContent(postId);
        
        PostContent mockContent = new PostContent();
        mockContent.setPostId(postId.toString());
        mockContent.setTitle("Test Post " + postId);
        mockContent.setRaw("Test content");
        
        // First check: cache miss
        // Second check (after lock): cache hit
        when(valueOperations.get(cacheKey))
            .thenReturn(null)  // First check: miss
            .thenReturn(mockContent);  // Second check (DCL): hit
        
        when(hotDataIdentifier.isHotData("post", postId)).thenReturn(true);
        when(hotDataIdentifier.isManuallyMarkedAsHot("post", postId)).thenReturn(false);
        when(redissonClient.getLock(lockKey)).thenReturn(lock);
        when(lock.tryLock(anyLong(), anyLong(), any(TimeUnit.class))).thenReturn(true);
        when(lock.isHeldByCurrentThread()).thenReturn(true);
        
        // When: Get post content
        PostContent result = cachedManager.getPostContent(postId);
        
        // Then: Should return cached content without querying database
        assertThat(result).isNotNull();
        assertThat(result.getPostId()).isEqualTo(postId.toString());
        
        // Verify database was NOT queried (DCL prevented it)
        verify(delegate, never()).getPostContent(postId);
        
        // Verify lock was acquired and released
        verify(lock).tryLock(anyLong(), anyLong(), any(TimeUnit.class));
        verify(lock).unlock();
    }
    
    /**
     * Property 2b: DCL with null value cache
     * For any entity ID, DCL should also work with null value cache
     */
    @Property(tries = 100)
    void dclWorksWithNullValueCache(@ForAll @LongRange(min = 1, max = 10000) Long postId) throws Exception {
        // Given: Cache miss on first check, null value on second check
        String cacheKey = PostRedisKeys.content(postId);
        String lockKey = PostRedisKeys.lockContent(postId);
        
        when(valueOperations.get(cacheKey))
            .thenReturn(null)  // First check: miss
            .thenReturn("NULL");  // Second check (DCL): null value cached
        
        when(hotDataIdentifier.isHotData("post", postId)).thenReturn(true);
        when(hotDataIdentifier.isManuallyMarkedAsHot("post", postId)).thenReturn(false);
        when(redissonClient.getLock(lockKey)).thenReturn(lock);
        when(lock.tryLock(anyLong(), anyLong(), any(TimeUnit.class))).thenReturn(true);
        when(lock.isHeldByCurrentThread()).thenReturn(true);
        
        // When: Get post content
        PostContent result = cachedManager.getPostContent(postId);
        
        // Then: Should return null without querying database
        assertThat(result).isNull();
        
        // Verify database was NOT queried (DCL prevented it)
        verify(delegate, never()).getPostContent(postId);
        
        // Verify lock was acquired and released
        verify(lock).tryLock(anyLong(), anyLong(), any(TimeUnit.class));
        verify(lock).unlock();
    }
}
