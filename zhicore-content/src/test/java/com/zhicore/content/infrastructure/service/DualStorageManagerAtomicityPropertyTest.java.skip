package com.zhicore.post.infrastructure.service;

import exception.domain.com.zhicore.content.DualStorageException;
import model.domain.com.zhicore.content.Post;
import model.domain.com.zhicore.content.PostStatus;
import repository.domain.com.zhicore.content.PostRepository;
import service.domain.com.zhicore.content.DualStorageManager;
import document.mongodb.infrastructure.com.zhicore.content.PostContent;
import repository.mongodb.infrastructure.com.zhicore.content.PostContentRepository;
import net.jqwik.api.*;
import net.jqwik.api.constraints.IntRange;
import net.jqwik.api.constraints.StringLength;
import net.jqwik.api.lifecycle.BeforeContainer;
import org.junit.jupiter.api.BeforeEach;
import org.mockito.Mockito;
import org.springframework.dao.DataAccessException;

import java.util.Optional;

import static org.assertj.core.api.Assertions.assertThat;
import static org.assertj.core.api.Assertions.assertThatThrownBy;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.ArgumentMatchers.anyString;
import static org.mockito.Mockito.*;

/**
 * Dual Storage Manager Atomicity Property Test
 * 
 * Uses property-based testing to validate dual-write atomicity between
 * PostgreSQL and MongoDB.
 * 
 * **Feature: post-mongodb-hybrid, Property 1: 双写原子性**
 * 
 * **Validates: Requirements 2.1, 2.3, 7.1**
 * 
 * Property 1: 双写原子性
 * 对于任意文章创建或更新操作，PostgreSQL 和 MongoDB 的写入要么全部成功，
 * 要么全部失败，不存在部分成功的情况。
 */
class DualStorageManagerAtomicityPropertyTest {

    private PostRepository postRepository;
    private PostContentRepository postContentRepository;
    private DualStorageManager dualStorageManager;

    @BeforeEach
    void setUp() {
        postRepository = mock(PostRepository.class);
        postContentRepository = mock(PostContentRepository.class);
        dualStorageManager = new DualStorageManagerImpl(postRepository, postContentRepository);
    }

    /**
     * Property 1: Dual-write atomicity - successful case
     * 
     * For any valid post and content, when both PostgreSQL and MongoDB writes succeed,
     * the operation should complete successfully and both databases should contain the data.
     * 
     * **Validates: Requirements 2.1, 7.1**
     */
    @Property(tries = 100)
    @Label("Property 1: Both databases should contain data when dual-write succeeds")
    void bothDatabasesShouldContainDataWhenDualWriteSucceeds(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @IntRange(min = 1, max = 100000) long ownerId,
            @ForAll @StringLength(min = 1, max = 200) String title,
            @ForAll @StringLength(min = 10, max = 5000) String content) {

        // Given: Valid post and content
        Post post = Post.createDraft(postId, ownerId, title);
        PostContent postContent = PostContent.builder()
                .postId(String.valueOf(postId))
                .contentType("markdown")
                .raw(content)
                .html("<p>" + content + "</p>")
                .text(content)
                .build();

        // Mock successful saves
        doNothing().when(postRepository).save(any(Post.class));
        when(postContentRepository.save(any(PostContent.class))).thenReturn(postContent);

        // When: Create post
        String resultPostId = dualStorageManager.createPost(post, postContent);

        // Then: Both repositories should be called
        assertThat(resultPostId).isEqualTo(String.valueOf(postId));
        verify(postRepository, times(1)).save(any(Post.class));
        verify(postContentRepository, times(1)).save(any(PostContent.class));
    }

    /**
     * Property 1: Dual-write atomicity - MongoDB failure triggers rollback
     * 
     * For any valid post and content, when PostgreSQL write succeeds but MongoDB fails,
     * the PostgreSQL transaction should be rolled back (via @Transactional).
     * 
     * **Validates: Requirements 2.3, 7.1**
     */
    @Property(tries = 100)
    @Label("Property 1: MongoDB failure should trigger PostgreSQL rollback")
    void mongoDBFailureShouldTriggerPostgreSQLRollback(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @IntRange(min = 1, max = 100000) long ownerId,
            @ForAll @StringLength(min = 1, max = 200) String title,
            @ForAll @StringLength(min = 10, max = 5000) String content) {

        // Given: Valid post and content
        Post post = Post.createDraft(postId, ownerId, title);
        PostContent postContent = PostContent.builder()
                .postId(String.valueOf(postId))
                .contentType("markdown")
                .raw(content)
                .build();

        // Mock PostgreSQL success but MongoDB failure
        doNothing().when(postRepository).save(any(Post.class));
        when(postContentRepository.save(any(PostContent.class)))
                .thenThrow(new RuntimeException("MongoDB connection failed"));

        // When & Then: Create post should throw exception
        assertThatThrownBy(() -> dualStorageManager.createPost(post, postContent))
                .isInstanceOf(DualStorageException.class)
                .hasMessageContaining("Failed to save content to MongoDB");

        // Verify PostgreSQL was called but MongoDB failure occurred
        verify(postRepository, times(1)).save(any(Post.class));
        verify(postContentRepository, times(1)).save(any(PostContent.class));
        
        // Note: In real scenario with @Transactional, PostgreSQL would be rolled back
        // This test verifies the exception is thrown, triggering the rollback mechanism
    }

    /**
     * Property 1: Dual-write atomicity - PostgreSQL failure prevents MongoDB write
     * 
     * For any valid post and content, when PostgreSQL write fails,
     * MongoDB should not be written to at all.
     * 
     * **Validates: Requirements 2.3, 7.1**
     */
    @Property(tries = 100)
    @Label("Property 1: PostgreSQL failure should prevent MongoDB write")
    void postgreSQLFailureShouldPreventMongoDBWrite(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @IntRange(min = 1, max = 100000) long ownerId,
            @ForAll @StringLength(min = 1, max = 200) String title,
            @ForAll @StringLength(min = 10, max = 5000) String content) {

        // Given: Valid post and content
        Post post = Post.createDraft(postId, ownerId, title);
        PostContent postContent = PostContent.builder()
                .postId(String.valueOf(postId))
                .contentType("markdown")
                .raw(content)
                .build();

        // Mock PostgreSQL failure
        doThrow(new RuntimeException("PostgreSQL connection failed"))
                .when(postRepository).save(any(Post.class));

        // When & Then: Create post should throw exception
        assertThatThrownBy(() -> dualStorageManager.createPost(post, postContent))
                .isInstanceOf(DualStorageException.class)
                .hasMessageContaining("Failed to save post to PostgreSQL");

        // Verify PostgreSQL was called but MongoDB was never called
        verify(postRepository, times(1)).save(any(Post.class));
        verify(postContentRepository, never()).save(any(PostContent.class));
    }

    /**
     * Property 1: Dual-write atomicity - update operation
     * 
     * For any valid post update, both PostgreSQL and MongoDB should be updated,
     * or neither should be updated if either fails.
     * 
     * **Validates: Requirements 2.1, 2.3, 7.1**
     */
    @Property(tries = 100)
    @Label("Property 1: Update should be atomic across both databases")
    void updateShouldBeAtomicAcrossBothDatabases(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @IntRange(min = 1, max = 100000) long ownerId,
            @ForAll @StringLength(min = 1, max = 200) String title,
            @ForAll @StringLength(min = 10, max = 5000) String content) {

        // Given: Existing post and updated content
        Post post = Post.createDraft(postId, ownerId, title);
        PostContent postContent = PostContent.builder()
                .postId(String.valueOf(postId))
                .contentType("markdown")
                .raw(content)
                .build();

        // Mock successful updates
        doNothing().when(postRepository).update(any(Post.class));
        when(postContentRepository.save(any(PostContent.class))).thenReturn(postContent);

        // When: Update post
        dualStorageManager.updatePost(post, postContent);

        // Then: Both repositories should be called
        verify(postRepository, times(1)).update(any(Post.class));
        verify(postContentRepository, times(1)).save(any(PostContent.class));
    }

    /**
     * Property 1: Dual-write atomicity - update with MongoDB failure
     * 
     * For any valid post update, when MongoDB update fails,
     * PostgreSQL update should be rolled back.
     * 
     * **Validates: Requirements 2.3, 7.1**
     */
    @Property(tries = 100)
    @Label("Property 1: Update MongoDB failure should trigger PostgreSQL rollback")
    void updateMongoDBFailureShouldTriggerPostgreSQLRollback(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @IntRange(min = 1, max = 100000) long ownerId,
            @ForAll @StringLength(min = 1, max = 200) String title,
            @ForAll @StringLength(min = 10, max = 5000) String content) {

        // Given: Existing post and updated content
        Post post = Post.createDraft(postId, ownerId, title);
        PostContent postContent = PostContent.builder()
                .postId(String.valueOf(postId))
                .contentType("markdown")
                .raw(content)
                .build();

        // Mock PostgreSQL success but MongoDB failure
        doNothing().when(postRepository).update(any(Post.class));
        when(postContentRepository.save(any(PostContent.class)))
                .thenThrow(new RuntimeException("MongoDB update failed"));

        // When & Then: Update should throw exception
        assertThatThrownBy(() -> dualStorageManager.updatePost(post, postContent))
                .isInstanceOf(DualStorageException.class)
                .hasMessageContaining("Failed to update content in MongoDB");

        // Verify both were called but MongoDB failed
        verify(postRepository, times(1)).update(any(Post.class));
        verify(postContentRepository, times(1)).save(any(PostContent.class));
    }

    /**
     * Property 1: Dual-write atomicity - delete operation
     * 
     * For any post deletion, both PostgreSQL and MongoDB should be deleted,
     * or neither should be deleted if either fails.
     * 
     * **Validates: Requirements 2.1, 2.3, 7.1**
     */
    @Property(tries = 100)
    @Label("Property 1: Delete should be atomic across both databases")
    void deleteShouldBeAtomicAcrossBothDatabases(
            @ForAll @IntRange(min = 1, max = 1000000) long postId) {

        // Given: Existing post
        String postIdStr = String.valueOf(postId);

        // Mock successful deletes
        doNothing().when(postRepository).delete(anyString());
        doNothing().when(postContentRepository).deleteByPostId(anyString());

        // When: Delete post
        dualStorageManager.deletePost(postIdStr);

        // Then: Both repositories should be called
        verify(postRepository, times(1)).delete(postIdStr);
        verify(postContentRepository, times(1)).deleteByPostId(postIdStr);
    }

    /**
     * Property 1: Dual-write atomicity - delete with MongoDB failure
     * 
     * For any post deletion, when MongoDB delete fails,
     * PostgreSQL delete should be rolled back.
     * 
     * **Validates: Requirements 2.3, 7.1**
     */
    @Property(tries = 100)
    @Label("Property 1: Delete MongoDB failure should trigger PostgreSQL rollback")
    void deleteMongoDBFailureShouldTriggerPostgreSQLRollback(
            @ForAll @IntRange(min = 1, max = 1000000) long postId) {

        // Given: Existing post
        String postIdStr = String.valueOf(postId);

        // Mock PostgreSQL success but MongoDB failure
        doNothing().when(postRepository).delete(anyString());
        doThrow(new RuntimeException("MongoDB delete failed"))
                .when(postContentRepository).deleteByPostId(anyString());

        // When & Then: Delete should throw exception
        assertThatThrownBy(() -> dualStorageManager.deletePost(postIdStr))
                .isInstanceOf(DualStorageException.class)
                .hasMessageContaining("Failed to delete content from MongoDB");

        // Verify both were called but MongoDB failed
        verify(postRepository, times(1)).delete(postIdStr);
        verify(postContentRepository, times(1)).deleteByPostId(postIdStr);
    }

    /**
     * Property 1: Dual-write atomicity - consistency check
     * 
     * For any successful create operation, querying both databases
     * should return consistent data.
     * 
     * **Validates: Requirements 2.1, 7.1**
     */
    @Property(tries = 100)
    @Label("Property 1: Successful create should result in consistent data")
    void successfulCreateShouldResultInConsistentData(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @IntRange(min = 1, max = 100000) long ownerId,
            @ForAll @StringLength(min = 1, max = 200) String title,
            @ForAll @StringLength(min = 10, max = 5000) String content) {

        // Given: Valid post and content
        Post post = Post.createDraft(postId, ownerId, title);
        PostContent postContent = PostContent.builder()
                .postId(String.valueOf(postId))
                .contentType("markdown")
                .raw(content)
                .build();

        // Mock successful saves and queries
        doNothing().when(postRepository).save(any(Post.class));
        when(postContentRepository.save(any(PostContent.class))).thenReturn(postContent);
        when(postRepository.findById(String.valueOf(postId))).thenReturn(Optional.of(post));
        when(postContentRepository.findByPostId(String.valueOf(postId))).thenReturn(Optional.of(postContent));

        // When: Create post and query it
        String resultPostId = dualStorageManager.createPost(post, postContent);
        DualStorageManager.PostDetail detail = dualStorageManager.getPostFullDetail(resultPostId);

        // Then: Both databases should return consistent data
        assertThat(detail).isNotNull();
        assertThat(detail.getPost()).isNotNull();
        assertThat(detail.getContent()).isNotNull();
        assertThat(detail.getPost().getId()).isEqualTo(postId);
        assertThat(detail.getContent().getPostId()).isEqualTo(String.valueOf(postId));
        assertThat(detail.getContent().getRaw()).isEqualTo(content);
    }

    /**
     * Property 1: Dual-write atomicity - idempotency check
     * 
     * For any post, attempting to create it multiple times with the same ID
     * should either succeed once or fail consistently.
     * 
     * **Validates: Requirements 2.1, 7.1**
     */
    @Property(tries = 50)
    @Label("Property 1: Duplicate create attempts should fail consistently")
    void duplicateCreateAttemptsShouldFailConsistently(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @IntRange(min = 1, max = 100000) long ownerId,
            @ForAll @StringLength(min = 1, max = 200) String title,
            @ForAll @StringLength(min = 10, max = 5000) String content) {

        // Given: Valid post and content
        Post post1 = Post.createDraft(postId, ownerId, title);
        Post post2 = Post.createDraft(postId, ownerId, title + " v2");
        PostContent postContent1 = PostContent.builder()
                .postId(String.valueOf(postId))
                .contentType("markdown")
                .raw(content)
                .build();
        PostContent postContent2 = PostContent.builder()
                .postId(String.valueOf(postId))
                .contentType("markdown")
                .raw(content + " updated")
                .build();

        // Mock first save succeeds, second fails due to duplicate key
        doNothing().when(postRepository).save(post1);
        doThrow(new RuntimeException("Duplicate key"))
                .when(postRepository).save(post2);
        when(postContentRepository.save(postContent1)).thenReturn(postContent1);

        // When: First create succeeds
        String resultPostId = dualStorageManager.createPost(post1, postContent1);
        assertThat(resultPostId).isEqualTo(String.valueOf(postId));

        // Then: Second create with same ID should fail
        assertThatThrownBy(() -> dualStorageManager.createPost(post2, postContent2))
                .isInstanceOf(DualStorageException.class);
    }
}
