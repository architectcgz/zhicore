package com.zhicore.post.infrastructure.service;

import service.domain.com.zhicore.content.VersionManager;
import document.mongodb.infrastructure.com.zhicore.content.PostContent;
import document.mongodb.infrastructure.com.zhicore.content.PostVersion;
import repository.mongodb.infrastructure.com.zhicore.content.PostContentRepository;
import repository.mongodb.infrastructure.com.zhicore.content.PostVersionRepository;
import net.jqwik.api.*;
import net.jqwik.api.constraints.IntRange;
import net.jqwik.api.constraints.StringLength;
import org.junit.jupiter.api.BeforeEach;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.context.SpringBootTest;
import org.springframework.data.domain.Page;
import org.springframework.test.context.DynamicPropertyRegistry;
import org.springframework.test.context.DynamicPropertySource;
import org.testcontainers.containers.MongoDBContainer;
import org.testcontainers.junit.jupiter.Container;
import org.testcontainers.junit.jupiter.Testcontainers;

import java.time.LocalDateTime;
import java.util.ArrayList;
import java.util.List;

import static org.assertj.core.api.Assertions.assertThat;

/**
 * Version Manager Sorting Property Test
 * 
 * Uses property-based testing to validate that version lists are
 * correctly sorted by editedAt in descending order (newest first).
 * 
 * **Feature: post-mongodb-hybrid, Property 7: 版本排序正确性**
 * 
 * **Validates: Requirements 3.2**
 * 
 * Property 7: 版本排序正确性
 * 对于任意文章的版本列表查询，返回的版本应该按编辑时间倒序排列，即最新的版本在最前面。
 */
@SpringBootTest
@Testcontainers
class VersionManagerSortingPropertyTest {

    @Container
    static MongoDBContainer mongoDBContainer = new MongoDBContainer("mongo:8.0")
            .withExposedPorts(27017);

    @DynamicPropertySource
    static void setProperties(DynamicPropertyRegistry registry) {
        registry.add("spring.data.mongodb.uri", mongoDBContainer::getReplicaSetUrl);
    }

    @Autowired
    private VersionManager versionManager;

    @Autowired
    private PostVersionRepository versionRepository;

    @Autowired
    private PostContentRepository contentRepository;

    @BeforeEach
    void setUp() {
        versionRepository.deleteAll();
        contentRepository.deleteAll();
    }

    /**
     * Property 7: Versions are sorted by editedAt descending
     * 
     * For any post with multiple versions, when querying the version list,
     * the versions should be sorted by editedAt in descending order
     * (newest first, oldest last).
     * 
     * **Validates: Requirements 3.2**
     */
    @Property(tries = 100)
    @Label("Property 7: Versions are sorted by editedAt descending")
    void versionsAreSortedByEditedAtDescending(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @IntRange(min = 1, max = 100000) long ownerId,
            @ForAll @IntRange(min = 2, max = 15) int versionCount,
            @ForAll @StringLength(min = 10, max = 500) String baseContent) {

        // Given: A post with multiple versions created over time
        String postIdStr = String.valueOf(postId);
        String ownerIdStr = String.valueOf(ownerId);

        // Create initial content in MongoDB
        PostContent initialContent = PostContent.builder()
                .postId(postIdStr)
                .contentType("markdown")
                .raw(baseContent)
                .html("<p>" + baseContent + "</p>")
                .text(baseContent)
                .createdAt(LocalDateTime.now())
                .updatedAt(LocalDateTime.now())
                .build();
        contentRepository.save(initialContent);

        // Create multiple versions with small time delays to ensure different timestamps
        List<LocalDateTime> creationTimes = new ArrayList<>();
        for (int i = 0; i < versionCount; i++) {
            String content = baseContent + " - Version " + (i + 1);
            
            versionManager.createVersion(
                    postIdStr,
                    content,
                    ownerIdStr,
                    "Change note " + (i + 1)
            );
            
            // Record the approximate creation time
            creationTimes.add(LocalDateTime.now());
            
            // Small delay to ensure different timestamps (in real scenario)
            try {
                Thread.sleep(10);
            } catch (InterruptedException e) {
                Thread.currentThread().interrupt();
            }
        }

        // When: Query the version list (first page)
        Page<PostVersion> versionPage = versionManager.getVersions(postIdStr, 0, versionCount);

        // Then: Versions should be sorted by editedAt descending
        List<PostVersion> versions = versionPage.getContent();
        assertThat(versions).hasSize(versionCount);

        // Verify descending order by editedAt
        for (int i = 1; i < versions.size(); i++) {
            LocalDateTime currentEditedAt = versions.get(i - 1).getEditedAt();
            LocalDateTime nextEditedAt = versions.get(i).getEditedAt();
            
            assertThat(currentEditedAt)
                    .as("Version at position %d should have editedAt >= version at position %d", i - 1, i)
                    .isAfterOrEqualTo(nextEditedAt);
        }

        // Verify the newest version is first
        assertThat(versions.get(0).getVersion())
                .as("First version in list should be the newest (highest version number)")
                .isEqualTo(versionCount);

        // Verify the oldest version is last
        assertThat(versions.get(versions.size() - 1).getVersion())
                .as("Last version in list should be the oldest (version 1)")
                .isEqualTo(1);
    }

    /**
     * Property 7: Pagination maintains sort order
     * 
     * For any post with multiple versions, when querying different pages,
     * the sort order should be maintained across all pages.
     * 
     * **Validates: Requirements 3.2**
     */
    @Property(tries = 100)
    @Label("Property 7: Pagination maintains sort order")
    void paginationMaintainsSortOrder(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @IntRange(min = 1, max = 100000) long ownerId,
            @ForAll @IntRange(min = 5, max = 20) int versionCount,
            @ForAll @IntRange(min = 2, max = 5) int pageSize,
            @ForAll @StringLength(min = 10, max = 500) String baseContent) {

        // Given: A post with multiple versions
        String postIdStr = String.valueOf(postId);
        String ownerIdStr = String.valueOf(ownerId);

        // Create initial content in MongoDB
        PostContent initialContent = PostContent.builder()
                .postId(postIdStr)
                .contentType("markdown")
                .raw(baseContent)
                .html("<p>" + baseContent + "</p>")
                .text(baseContent)
                .createdAt(LocalDateTime.now())
                .updatedAt(LocalDateTime.now())
                .build();
        contentRepository.save(initialContent);

        // Create multiple versions
        for (int i = 0; i < versionCount; i++) {
            String content = baseContent + " - Version " + (i + 1);
            
            versionManager.createVersion(
                    postIdStr,
                    content,
                    ownerIdStr,
                    "Change note " + (i + 1)
            );
            
            // Small delay to ensure different timestamps
            try {
                Thread.sleep(5);
            } catch (InterruptedException e) {
                Thread.currentThread().interrupt();
            }
        }

        // When: Query multiple pages
        List<PostVersion> allVersionsFromPages = new ArrayList<>();
        int totalPages = (int) Math.ceil((double) versionCount / pageSize);

        for (int page = 0; page < totalPages; page++) {
            Page<PostVersion> versionPage = versionManager.getVersions(postIdStr, page, pageSize);
            allVersionsFromPages.addAll(versionPage.getContent());
        }

        // Then: All versions should be in descending order by editedAt
        assertThat(allVersionsFromPages).hasSize(versionCount);

        for (int i = 1; i < allVersionsFromPages.size(); i++) {
            LocalDateTime currentEditedAt = allVersionsFromPages.get(i - 1).getEditedAt();
            LocalDateTime nextEditedAt = allVersionsFromPages.get(i).getEditedAt();
            
            assertThat(currentEditedAt)
                    .as("Version at position %d should have editedAt >= version at position %d", i - 1, i)
                    .isAfterOrEqualTo(nextEditedAt);
        }

        // Verify version numbers are in descending order
        for (int i = 1; i < allVersionsFromPages.size(); i++) {
            Integer currentVersion = allVersionsFromPages.get(i - 1).getVersion();
            Integer nextVersion = allVersionsFromPages.get(i).getVersion();
            
            assertThat(currentVersion)
                    .as("Version number at position %d should be >= version at position %d", i - 1, i)
                    .isGreaterThanOrEqualTo(nextVersion);
        }
    }

    /**
     * Property 7: First page contains newest versions
     * 
     * For any post with multiple versions, the first page should always
     * contain the newest versions (highest version numbers).
     * 
     * **Validates: Requirements 3.2**
     */
    @Property(tries = 100)
    @Label("Property 7: First page contains newest versions")
    void firstPageContainsNewestVersions(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @IntRange(min = 1, max = 100000) long ownerId,
            @ForAll @IntRange(min = 5, max = 20) int versionCount,
            @ForAll @IntRange(min = 2, max = 5) int pageSize,
            @ForAll @StringLength(min = 10, max = 500) String baseContent) {

        // Given: A post with multiple versions
        String postIdStr = String.valueOf(postId);
        String ownerIdStr = String.valueOf(ownerId);

        // Create initial content in MongoDB
        PostContent initialContent = PostContent.builder()
                .postId(postIdStr)
                .contentType("markdown")
                .raw(baseContent)
                .html("<p>" + baseContent + "</p>")
                .text(baseContent)
                .createdAt(LocalDateTime.now())
                .updatedAt(LocalDateTime.now())
                .build();
        contentRepository.save(initialContent);

        // Create multiple versions
        for (int i = 0; i < versionCount; i++) {
            String content = baseContent + " - Version " + (i + 1);
            
            versionManager.createVersion(
                    postIdStr,
                    content,
                    ownerIdStr,
                    "Change note " + (i + 1)
            );
            
            // Small delay to ensure different timestamps
            try {
                Thread.sleep(5);
            } catch (InterruptedException e) {
                Thread.currentThread().interrupt();
            }
        }

        // When: Query the first page
        Page<PostVersion> firstPage = versionManager.getVersions(postIdStr, 0, pageSize);

        // Then: The first page should contain the newest versions
        List<PostVersion> versions = firstPage.getContent();
        assertThat(versions).isNotEmpty();

        // The first version in the first page should be the newest (highest version number)
        assertThat(versions.get(0).getVersion())
                .as("First version should be the newest")
                .isEqualTo(versionCount);

        // All versions in the first page should have higher version numbers than any version not in the first page
        int minVersionInFirstPage = versions.stream()
                .map(PostVersion::getVersion)
                .min(Integer::compareTo)
                .orElse(0);

        // If there are more pages, verify the next page has lower version numbers
        if (versionCount > pageSize) {
            Page<PostVersion> secondPage = versionManager.getVersions(postIdStr, 1, pageSize);
            if (!secondPage.isEmpty()) {
                int maxVersionInSecondPage = secondPage.getContent().stream()
                        .map(PostVersion::getVersion)
                        .max(Integer::compareTo)
                        .orElse(Integer.MAX_VALUE);

                assertThat(minVersionInFirstPage)
                        .as("Minimum version in first page should be > maximum version in second page")
                        .isGreaterThan(maxVersionInSecondPage);
            }
        }
    }

    /**
     * Property 7: Sort order is consistent across multiple queries
     * 
     * For any post, querying the version list multiple times should
     * return the same sort order each time.
     * 
     * **Validates: Requirements 3.2**
     */
    @Property(tries = 100)
    @Label("Property 7: Sort order is consistent across multiple queries")
    void sortOrderIsConsistentAcrossMultipleQueries(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @IntRange(min = 1, max = 100000) long ownerId,
            @ForAll @IntRange(min = 3, max = 10) int versionCount,
            @ForAll @StringLength(min = 10, max = 500) String baseContent) {

        // Given: A post with multiple versions
        String postIdStr = String.valueOf(postId);
        String ownerIdStr = String.valueOf(ownerId);

        // Create initial content in MongoDB
        PostContent initialContent = PostContent.builder()
                .postId(postIdStr)
                .contentType("markdown")
                .raw(baseContent)
                .html("<p>" + baseContent + "</p>")
                .text(baseContent)
                .createdAt(LocalDateTime.now())
                .updatedAt(LocalDateTime.now())
                .build();
        contentRepository.save(initialContent);

        // Create multiple versions
        for (int i = 0; i < versionCount; i++) {
            String content = baseContent + " - Version " + (i + 1);
            
            versionManager.createVersion(
                    postIdStr,
                    content,
                    ownerIdStr,
                    "Change note " + (i + 1)
            );
            
            // Small delay to ensure different timestamps
            try {
                Thread.sleep(5);
            } catch (InterruptedException e) {
                Thread.currentThread().interrupt();
            }
        }

        // When: Query the version list multiple times
        Page<PostVersion> firstQuery = versionManager.getVersions(postIdStr, 0, versionCount);
        Page<PostVersion> secondQuery = versionManager.getVersions(postIdStr, 0, versionCount);
        Page<PostVersion> thirdQuery = versionManager.getVersions(postIdStr, 0, versionCount);

        // Then: All queries should return the same order
        List<Integer> firstOrder = firstQuery.getContent().stream()
                .map(PostVersion::getVersion)
                .toList();
        
        List<Integer> secondOrder = secondQuery.getContent().stream()
                .map(PostVersion::getVersion)
                .toList();
        
        List<Integer> thirdOrder = thirdQuery.getContent().stream()
                .map(PostVersion::getVersion)
                .toList();

        assertThat(firstOrder)
                .as("First and second query should return same order")
                .isEqualTo(secondOrder);
        
        assertThat(firstOrder)
                .as("First and third query should return same order")
                .isEqualTo(thirdOrder);

        // Verify all are in descending order
        for (int i = 1; i < firstOrder.size(); i++) {
            assertThat(firstOrder.get(i - 1))
                    .as("Version at position %d should be >= version at position %d", i - 1, i)
                    .isGreaterThanOrEqualTo(firstOrder.get(i));
        }
    }

    /**
     * Property 7: Empty result maintains sort contract
     * 
     * For any post with no versions, querying the version list should
     * return an empty result without errors.
     * 
     * **Validates: Requirements 3.2**
     */
    @Property(tries = 100)
    @Label("Property 7: Empty result maintains sort contract")
    void emptyResultMaintainsSortContract(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @IntRange(min = 1, max = 20) int pageSize) {

        // Given: A post with no versions
        String postIdStr = String.valueOf(postId);

        // When: Query the version list
        Page<PostVersion> versionPage = versionManager.getVersions(postIdStr, 0, pageSize);

        // Then: Should return empty result without errors
        assertThat(versionPage.getContent()).isEmpty();
        assertThat(versionPage.getTotalElements()).isEqualTo(0);
        assertThat(versionPage.getTotalPages()).isEqualTo(0);
    }

    /**
     * Property 7: Single version is correctly sorted
     * 
     * For any post with exactly one version, querying the version list
     * should return that single version.
     * 
     * **Validates: Requirements 3.2**
     */
    @Property(tries = 100)
    @Label("Property 7: Single version is correctly sorted")
    void singleVersionIsCorrectlySorted(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @IntRange(min = 1, max = 100000) long ownerId,
            @ForAll @StringLength(min = 10, max = 500) String content,
            @ForAll @StringLength(min = 1, max = 200) String changeNote) {

        // Given: A post with exactly one version
        String postIdStr = String.valueOf(postId);
        String ownerIdStr = String.valueOf(ownerId);

        // Create initial content in MongoDB
        PostContent initialContent = PostContent.builder()
                .postId(postIdStr)
                .contentType("markdown")
                .raw(content)
                .html("<p>" + content + "</p>")
                .text(content)
                .createdAt(LocalDateTime.now())
                .updatedAt(LocalDateTime.now())
                .build();
        contentRepository.save(initialContent);

        // Create one version
        versionManager.createVersion(postIdStr, content, ownerIdStr, changeNote);

        // When: Query the version list
        Page<PostVersion> versionPage = versionManager.getVersions(postIdStr, 0, 10);

        // Then: Should return exactly one version
        assertThat(versionPage.getContent()).hasSize(1);
        assertThat(versionPage.getTotalElements()).isEqualTo(1);

        PostVersion version = versionPage.getContent().get(0);
        assertThat(version.getVersion()).isEqualTo(1);
        assertThat(version.getPostId()).isEqualTo(postIdStr);
        assertThat(version.getContent()).isEqualTo(content);
        assertThat(version.getEditedBy()).isEqualTo(ownerIdStr);
        assertThat(version.getChangeNote()).isEqualTo(changeNote);
    }

    /**
     * Property 7: Versions with same editedAt are sorted by version number
     * 
     * For any post where multiple versions might have the same editedAt
     * (due to rapid creation), they should be sorted by version number
     * in descending order as a secondary sort key.
     * 
     * **Validates: Requirements 3.2**
     */
    @Property(tries = 100)
    @Label("Property 7: Versions with same editedAt are sorted by version number")
    void versionsWithSameEditedAtAreSortedByVersionNumber(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @IntRange(min = 1, max = 100000) long ownerId,
            @ForAll @IntRange(min = 3, max = 10) int versionCount,
            @ForAll @StringLength(min = 10, max = 500) String baseContent) {

        // Given: A post with multiple versions created rapidly
        String postIdStr = String.valueOf(postId);
        String ownerIdStr = String.valueOf(ownerId);

        // Create initial content in MongoDB
        PostContent initialContent = PostContent.builder()
                .postId(postIdStr)
                .contentType("markdown")
                .raw(baseContent)
                .html("<p>" + baseContent + "</p>")
                .text(baseContent)
                .createdAt(LocalDateTime.now())
                .updatedAt(LocalDateTime.now())
                .build();
        contentRepository.save(initialContent);

        // Create multiple versions rapidly (no delay)
        for (int i = 0; i < versionCount; i++) {
            String content = baseContent + " - Version " + (i + 1);
            
            versionManager.createVersion(
                    postIdStr,
                    content,
                    ownerIdStr,
                    "Change note " + (i + 1)
            );
        }

        // When: Query the version list
        Page<PostVersion> versionPage = versionManager.getVersions(postIdStr, 0, versionCount);

        // Then: Versions should be sorted by version number descending
        List<PostVersion> versions = versionPage.getContent();
        assertThat(versions).hasSize(versionCount);

        // Verify version numbers are in descending order
        for (int i = 1; i < versions.size(); i++) {
            Integer currentVersion = versions.get(i - 1).getVersion();
            Integer nextVersion = versions.get(i).getVersion();
            
            assertThat(currentVersion)
                    .as("Version at position %d should be > version at position %d", i - 1, i)
                    .isGreaterThan(nextVersion);
        }

        // Verify the newest version is first
        assertThat(versions.get(0).getVersion()).isEqualTo(versionCount);
        
        // Verify the oldest version is last
        assertThat(versions.get(versions.size() - 1).getVersion()).isEqualTo(1);
    }
}
