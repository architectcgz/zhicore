package com.zhicore.post.infrastructure.service;

import com.zhicore.common.cache.HotDataIdentifier;
import com.zhicore.common.config.CacheProperties;
import cache.infrastructure.com.zhicore.content.PostRedisKeys;
import net.jqwik.api.*;
import org.junit.jupiter.api.BeforeEach;
import org.mockito.ArgumentCaptor;
import org.mockito.Mock;
import org.mockito.MockitoAnnotations;
import org.redisson.api.RLock;
import org.redisson.api.RedissonClient;
import org.springframework.data.redis.core.RedisTemplate;
import org.springframework.data.redis.core.ValueOperations;

import java.util.concurrent.TimeUnit;

import static org.assertj.core.api.Assertions.assertThat;
import static org.mockito.ArgumentMatchers.*;
import static org.mockito.Mockito.*;

/**
 * Feature: cache-penetration-protection, Property 6: 空值缓存防穿透
 * Validates: Requirements 1.7, 2.3, 3.3
 * 
 * Property: For any non-existent entity ID, null value should be cached,
 * and subsequent queries should not access database.
 */
class CachedDualStorageManagerNullValueCachePropertyTest {

    @Mock
    private DualStorageManager delegate;
    
    @Mock
    private RedisTemplate<String, Object> redisTemplate;
    
    @Mock
    private RedissonClient redissonClient;
    
    @Mock
    private HotDataIdentifier hotDataIdentifier;
    
    @Mock
    private ValueOperations<String, Object> valueOperations;
    
    @Mock
    private RLock lock;
    
    private CacheProperties cacheProperties;
    private CachedDualStorageManager cachedManager;

    @BeforeEach
    void setUp() {
        MockitoAnnotations.openMocks(this);
        
        cacheProperties = new CacheProperties();
        cacheProperties.setEntityDetail(600);
        cacheProperties.setLockWaitTime(5);
        cacheProperties.setLockLeaseTime(10);
        cacheProperties.setNullValueTtl(60);
        cacheProperties.setHotDataIdentificationEnabled(true);
        
        cachedManager = new CachedDualStorageManager(
            delegate,
            redisTemplate,
            redissonClient,
            hotDataIdentifier,
            cacheProperties
        );
        
        when(redisTemplate.opsForValue()).thenReturn(valueOperations);
    }

    /**
     * Property 6: 空值缓存防穿透
     * For any non-existent entity ID, null value should be cached
     */
    @Property(tries = 100)
    void nullValueCached(@ForAll @LongRange(min = 1, max = 10000) Long postId) throws Exception {
        // Given: Cache miss, hot data, but entity doesn't exist in database
        String cacheKey = PostRedisKeys.content(postId);
        String lockKey = PostRedisKeys.lockContent(postId);
        
        when(valueOperations.get(cacheKey)).thenReturn(null);
        when(hotDataIdentifier.isHotData("post", postId)).thenReturn(true);
        when(hotDataIdentifier.isManuallyMarkedAsHot("post", postId)).thenReturn(false);
        when(redissonClient.getLock(lockKey)).thenReturn(lock);
        when(lock.tryLock(anyLong(), anyLong(), any(TimeUnit.class))).thenReturn(true);
        when(lock.isHeldByCurrentThread()).thenReturn(true);
        
        // Database returns null (entity doesn't exist)
        when(delegate.getPostContent(postId)).thenReturn(null);
        
        // When: Get post content (will return null)
        var result = cachedManager.getPostContent(postId);
        
        // Then: Should return null
        assertThat(result).isNull();
        
        // Verify null value was cached with shorter TTL
        ArgumentCaptor<String> keyCaptor = ArgumentCaptor.forClass(String.class);
        ArgumentCaptor<Object> valueCaptor = ArgumentCaptor.forClass(Object.class);
        ArgumentCaptor<Long> ttlCaptor = ArgumentCaptor.forClass(Long.class);
        ArgumentCaptor<TimeUnit> unitCaptor = ArgumentCaptor.forClass(TimeUnit.class);
        
        verify(valueOperations).set(keyCaptor.capture(), valueCaptor.capture(), 
            ttlCaptor.capture(), unitCaptor.capture());
        
        assertThat(keyCaptor.getValue()).isEqualTo(cacheKey);
        assertThat(valueCaptor.getValue()).isEqualTo("NULL");
        assertThat(ttlCaptor.getValue()).isEqualTo(cacheProperties.getNullValueTtl());
        assertThat(unitCaptor.getValue()).isEqualTo(TimeUnit.SECONDS);
    }
    
    /**
     * Property 6b: Subsequent queries don't access database
     */
    @Property(tries = 100)
    void subsequentQueriesUseCachedNull(@ForAll @LongRange(min = 1, max = 10000) Long postId) {
        // Given: Null value already cached
        String cacheKey = PostRedisKeys.content(postId);
        
        when(valueOperations.get(cacheKey)).thenReturn("NULL");
        when(hotDataIdentifier.isHotData("post", postId)).thenReturn(true);
        
        // When: Get post content (should use cached null)
        var result = cachedManager.getPostContent(postId);
        
        // Then: Should return null without querying database
        assertThat(result).isNull();
        verify(delegate, never()).getPostContent(postId);
        verify(redissonClient, never()).getLock(anyString());
    }
}
