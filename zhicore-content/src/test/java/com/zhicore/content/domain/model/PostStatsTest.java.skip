package com.zhicore.post.domain.model;

import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Nested;
import org.junit.jupiter.api.Test;

import static org.junit.jupiter.api.Assertions.*;

/**
 * PostStats 值对象单元测试
 * 
 * 测试点赞计数一致性和不可变性
 *
 * @author ZhiCore Team
 */
@DisplayName("PostStats 值对象测试")
class PostStatsTest {

    @Nested
    @DisplayName("创建统计")
    class CreateStats {

        @Test
        @DisplayName("应该成功创建空统计")
        void shouldCreateEmptyStats() {
            // When
            PostStats stats = PostStats.empty();

            // Then
            assertEquals(0, stats.getLikeCount());
            assertEquals(0, stats.getCommentCount());
            assertEquals(0, stats.getFavoriteCount());
            assertEquals(0, stats.getViewCount());
        }

        @Test
        @DisplayName("应该成功创建带初始值的统计")
        void shouldCreateStatsWithValues() {
            // When
            PostStats stats = new PostStats(10, 5, 3, 100);

            // Then
            assertEquals(10, stats.getLikeCount());
            assertEquals(5, stats.getCommentCount());
            assertEquals(3, stats.getFavoriteCount());
            assertEquals(100, stats.getViewCount());
        }

        @Test
        @DisplayName("负数应该被修正为0")
        void shouldCorrectNegativeValues() {
            // When
            PostStats stats = new PostStats(-5, -3, -2, -100);

            // Then
            assertEquals(0, stats.getLikeCount());
            assertEquals(0, stats.getCommentCount());
            assertEquals(0, stats.getFavoriteCount());
            assertEquals(0, stats.getViewCount());
        }
    }

    @Nested
    @DisplayName("点赞计数操作")
    class LikeCountOperations {

        @Test
        @DisplayName("增加点赞数应该返回新对象")
        void shouldReturnNewObjectWhenIncrementingLikes() {
            // Given
            PostStats original = new PostStats(10, 5, 3, 100);

            // When
            PostStats incremented = original.incrementLikes();

            // Then
            assertEquals(11, incremented.getLikeCount());
            assertEquals(10, original.getLikeCount()); // 原对象不变
            assertNotSame(original, incremented);
        }

        @Test
        @DisplayName("减少点赞数应该返回新对象")
        void shouldReturnNewObjectWhenDecrementingLikes() {
            // Given
            PostStats original = new PostStats(10, 5, 3, 100);

            // When
            PostStats decremented = original.decrementLikes();

            // Then
            assertEquals(9, decremented.getLikeCount());
            assertEquals(10, original.getLikeCount()); // 原对象不变
            assertNotSame(original, decremented);
        }

        @Test
        @DisplayName("点赞数减到0后不应该变为负数")
        void shouldNotGoNegativeWhenDecrementing() {
            // Given
            PostStats stats = new PostStats(0, 0, 0, 0);

            // When
            PostStats decremented = stats.decrementLikes();

            // Then
            assertEquals(0, decremented.getLikeCount());
        }

        @Test
        @DisplayName("连续增加点赞数应该正确累加")
        void shouldAccumulateLikesCorrectly() {
            // Given
            PostStats stats = PostStats.empty();

            // When
            PostStats result = stats
                    .incrementLikes()
                    .incrementLikes()
                    .incrementLikes();

            // Then
            assertEquals(3, result.getLikeCount());
            assertEquals(0, stats.getLikeCount()); // 原对象不变
        }
    }

    @Nested
    @DisplayName("评论计数操作")
    class CommentCountOperations {

        @Test
        @DisplayName("增加评论数应该返回新对象")
        void shouldReturnNewObjectWhenIncrementingComments() {
            // Given
            PostStats original = new PostStats(10, 5, 3, 100);

            // When
            PostStats incremented = original.incrementComments();

            // Then
            assertEquals(6, incremented.getCommentCount());
            assertEquals(5, original.getCommentCount());
        }

        @Test
        @DisplayName("减少评论数应该返回新对象")
        void shouldReturnNewObjectWhenDecrementingComments() {
            // Given
            PostStats original = new PostStats(10, 5, 3, 100);

            // When
            PostStats decremented = original.decrementComments();

            // Then
            assertEquals(4, decremented.getCommentCount());
            assertEquals(5, original.getCommentCount());
        }

        @Test
        @DisplayName("评论数减到0后不应该变为负数")
        void shouldNotGoNegativeWhenDecrementing() {
            // Given
            PostStats stats = new PostStats(0, 0, 0, 0);

            // When
            PostStats decremented = stats.decrementComments();

            // Then
            assertEquals(0, decremented.getCommentCount());
        }
    }

    @Nested
    @DisplayName("收藏计数操作")
    class FavoriteCountOperations {

        @Test
        @DisplayName("增加收藏数应该返回新对象")
        void shouldReturnNewObjectWhenIncrementingFavorites() {
            // Given
            PostStats original = new PostStats(10, 5, 3, 100);

            // When
            PostStats incremented = original.incrementFavorites();

            // Then
            assertEquals(4, incremented.getFavoriteCount());
            assertEquals(3, original.getFavoriteCount());
        }

        @Test
        @DisplayName("减少收藏数应该返回新对象")
        void shouldReturnNewObjectWhenDecrementingFavorites() {
            // Given
            PostStats original = new PostStats(10, 5, 3, 100);

            // When
            PostStats decremented = original.decrementFavorites();

            // Then
            assertEquals(2, decremented.getFavoriteCount());
            assertEquals(3, original.getFavoriteCount());
        }

        @Test
        @DisplayName("收藏数减到0后不应该变为负数")
        void shouldNotGoNegativeWhenDecrementing() {
            // Given
            PostStats stats = new PostStats(0, 0, 0, 0);

            // When
            PostStats decremented = stats.decrementFavorites();

            // Then
            assertEquals(0, decremented.getFavoriteCount());
        }
    }

    @Nested
    @DisplayName("浏览量操作")
    class ViewCountOperations {

        @Test
        @DisplayName("增加浏览量应该返回新对象")
        void shouldReturnNewObjectWhenIncrementingViews() {
            // Given
            PostStats original = new PostStats(10, 5, 3, 100);

            // When
            PostStats incremented = original.incrementViews();

            // Then
            assertEquals(101, incremented.getViewCount());
            assertEquals(100, original.getViewCount());
        }
    }

    @Nested
    @DisplayName("值对象相等性")
    class Equality {

        @Test
        @DisplayName("相同值的统计应该相等")
        void shouldBeEqualWithSameValues() {
            // Given
            PostStats stats1 = new PostStats(10, 5, 3, 100);
            PostStats stats2 = new PostStats(10, 5, 3, 100);

            // Then
            assertEquals(stats1, stats2);
            assertEquals(stats1.hashCode(), stats2.hashCode());
        }

        @Test
        @DisplayName("不同值的统计应该不相等")
        void shouldNotBeEqualWithDifferentValues() {
            // Given
            PostStats stats1 = new PostStats(10, 5, 3, 100);
            PostStats stats2 = new PostStats(11, 5, 3, 100);

            // Then
            assertNotEquals(stats1, stats2);
        }

        @Test
        @DisplayName("与null比较应该不相等")
        void shouldNotBeEqualToNull() {
            // Given
            PostStats stats = new PostStats(10, 5, 3, 100);

            // Then
            assertNotEquals(null, stats);
        }
    }

    @Nested
    @DisplayName("不可变性验证")
    class Immutability {

        @Test
        @DisplayName("所有操作都应该返回新对象而不修改原对象")
        void shouldNotModifyOriginalObject() {
            // Given
            PostStats original = new PostStats(10, 5, 3, 100);
            int originalLikes = original.getLikeCount();
            int originalComments = original.getCommentCount();
            int originalFavorites = original.getFavoriteCount();
            long originalViews = original.getViewCount();

            // When - 执行所有操作
            original.incrementLikes();
            original.decrementLikes();
            original.incrementComments();
            original.decrementComments();
            original.incrementFavorites();
            original.decrementFavorites();
            original.incrementViews();

            // Then - 原对象应该保持不变
            assertEquals(originalLikes, original.getLikeCount());
            assertEquals(originalComments, original.getCommentCount());
            assertEquals(originalFavorites, original.getFavoriteCount());
            assertEquals(originalViews, original.getViewCount());
        }
    }
}
