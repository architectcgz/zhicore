package com.blog.post.domain.model;

import com.blog.common.exception.DomainException;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Nested;
import org.junit.jupiter.api.Test;

import java.time.LocalDateTime;

import static org.junit.jupiter.api.Assertions.*;

/**
 * Post иҒҡеҗҲж №еҚ•е…ғжөӢиҜ?
 * 
 * жөӢиҜ• Post иҒҡеҗҲж №зҠ¶жҖҒжңәе’ҢйўҶеҹҹиЎҢдё?
 *
 * @author Blog Team
 */
@DisplayName("Post иҒҡеҗҲж №жөӢиҜ?)
class PostTest {

    @Nested
    @DisplayName("еҲӣе»әиҚүзЁҝ")
    class CreateDraft {

        @Test
        @DisplayName("еә”иҜҘжҲҗеҠҹеҲӣе»әиҚүзЁҝ")
        void shouldCreateDraftSuccessfully() {
            // Given
            Long id = 1L;
            Long ownerId = 123L;
            String title = "жөӢиҜ•ж–Үз« ";
            String content = "иҝҷжҳҜж–Үз« еҶ…е®№";

            // When
            Post post = Post.createDraft(id, ownerId, title, content);

            // Then
            assertNotNull(post);
            assertEquals(id, post.getId());
            assertEquals(ownerId, post.getOwnerId());
            assertEquals(title, post.getTitle());
            assertEquals(content, post.getRaw());
            assertEquals(PostStatus.DRAFT, post.getStatus());
            assertNotNull(post.getCreatedAt());
            assertNotNull(post.getUpdatedAt());
            assertNotNull(post.getStats());
            assertTrue(post.isDraft());
            assertFalse(post.isPublished());
            assertFalse(post.isDeleted());
        }

        @Test
        @DisplayName("ж–Үз« IDдёәз©әж—¶еә”иҜҘжҠӣеҮәејӮеё?)
        void shouldThrowExceptionWhenIdIsNull() {
            assertThrows(IllegalArgumentException.class, () ->
                    Post.createDraft(null, 123L, "ж Үйўҳ", "еҶ…е®№"));
        }

        @Test
        @DisplayName("дҪңиҖ…IDдёәз©әж—¶еә”иҜҘжҠӣеҮәејӮеё?)
        void shouldThrowExceptionWhenOwnerIdIsEmpty() {
            assertThrows(IllegalArgumentException.class, () ->
                    Post.createDraft(1L, null, "ж Үйўҳ", "еҶ…е®№"));
        }

        @Test
        @DisplayName("ж Үйўҳдёәз©әж—¶еә”иҜҘжҠӣеҮәејӮеё?)
        void shouldThrowExceptionWhenTitleIsEmpty() {
            assertThrows(IllegalArgumentException.class, () ->
                    Post.createDraft(1L, 123L, "", "еҶ…е®№"));
        }
    }

    @Nested
    @DisplayName("еҸ‘еёғж–Үз«  - зҠ¶жҖҒжңәжөӢиҜ•")
    class PublishPost {

        @Test
        @DisplayName("иҚүзЁҝзҠ¶жҖҒеә”иҜҘеҸҜд»ҘеҸ‘её?)
        void shouldPublishFromDraft() {
            // Given
            Post post = Post.createDraft(1L, 123L, "ж Үйўҳ", "еҶ…е®№");
            assertTrue(post.isDraft());

            // When
            post.publish();

            // Then
            assertEquals(PostStatus.PUBLISHED, post.getStatus());
            assertTrue(post.isPublished());
            assertNotNull(post.getPublishedAt());
            assertNull(post.getScheduledAt());
        }

        @Test
        @DisplayName("е®ҡж—¶еҸ‘еёғзҠ¶жҖҒеә”иҜҘеҸҜд»ҘеҸ‘её?)
        void shouldPublishFromScheduled() {
            // Given
            Post post = Post.createDraft(1L, 123L, "ж Үйўҳ", "еҶ…е®№");
            post.schedulePublish(LocalDateTime.now().plusDays(1));
            assertEquals(PostStatus.SCHEDULED, post.getStatus());

            // When
            post.publish();

            // Then
            assertEquals(PostStatus.PUBLISHED, post.getStatus());
            assertTrue(post.isPublished());
        }

        @Test
        @DisplayName("е·ІеҸ‘еёғзҠ¶жҖҒйҮҚеӨҚеҸ‘еёғеә”иҜҘжҠӣеҮәејӮеё?)
        void shouldThrowExceptionWhenPublishingAlreadyPublished() {
            // Given
            Post post = Post.createDraft(1L, 123L, "ж Үйўҳ", "еҶ…е®№");
            post.publish();

            // When & Then
            DomainException exception = assertThrows(DomainException.class, post::publish);
            assertTrue(exception.getMessage().contains("е·Із»ҸеҸ‘еёғ"));
        }

        @Test
        @DisplayName("е·ІеҲ йҷӨзҠ¶жҖҒеҸ‘еёғеә”иҜҘжҠӣеҮәејӮеё?)
        void shouldThrowExceptionWhenPublishingDeleted() {
            // Given
            Post post = Post.createDraft(1L, 123L, "ж Үйўҳ", "еҶ…е®№");
            post.delete();

            // When & Then
            DomainException exception = assertThrows(DomainException.class, post::publish);
            assertTrue(exception.getMessage().contains("е·ІеҲ йҷ?));
        }
    }

    @Nested
    @DisplayName("е®ҡж—¶еҸ‘еёғ - зҠ¶жҖҒжңәжөӢиҜ•")
    class SchedulePublish {

        @Test
        @DisplayName("иҚүзЁҝзҠ¶жҖҒеә”иҜҘеҸҜд»Ҙи®ҫзҪ®е®ҡж—¶еҸ‘её?)
        void shouldScheduleFromDraft() {
            // Given
            Post post = Post.createDraft(1L, 123L, "ж Үйўҳ", "еҶ…е®№");
            LocalDateTime scheduledTime = LocalDateTime.now().plusDays(1);

            // When
            post.schedulePublish(scheduledTime);

            // Then
            assertEquals(PostStatus.SCHEDULED, post.getStatus());
            assertEquals(scheduledTime, post.getScheduledAt());
        }

        @Test
        @DisplayName("е·ІеҸ‘еёғзҠ¶жҖҒи®ҫзҪ®е®ҡж—¶еҸ‘еёғеә”иҜҘжҠӣеҮәејӮеё?)
        void shouldThrowExceptionWhenSchedulingPublished() {
            // Given
            Post post = Post.createDraft(1L, 123L, "ж Үйўҳ", "еҶ…е®№");
            post.publish();

            // When & Then
            DomainException exception = assertThrows(DomainException.class, () ->
                    post.schedulePublish(LocalDateTime.now().plusDays(1)));
            assertTrue(exception.getMessage().contains("иҚүзЁҝзҠ¶жҖ?));
        }

        @Test
        @DisplayName("е®ҡж—¶еҸ‘еёғж—¶й—ҙдёәз©әеә”иҜҘжҠӣеҮәејӮеёё")
        void shouldThrowExceptionWhenScheduledTimeIsNull() {
            // Given
            Post post = Post.createDraft(1L, 123L, "ж Үйўҳ", "еҶ…е®№");

            // When & Then
            DomainException exception = assertThrows(DomainException.class, () ->
                    post.schedulePublish(null));
            assertTrue(exception.getMessage().contains("дёҚиғҪдёәз©ә"));
        }

        @Test
        @DisplayName("е®ҡж—¶еҸ‘еёғж—¶й—ҙж—©дәҺеҪ“еүҚж—¶й—ҙеә”иҜҘжҠӣеҮәејӮеёё")
        void shouldThrowExceptionWhenScheduledTimeInPast() {
            // Given
            Post post = Post.createDraft(1L, 123L, "ж Үйўҳ", "еҶ…е®№");

            // When & Then
            DomainException exception = assertThrows(DomainException.class, () ->
                    post.schedulePublish(LocalDateTime.now().minusDays(1)));
            assertTrue(exception.getMessage().contains("дёҚиғҪж—©дәҺ"));
        }
    }

    @Nested
    @DisplayName("жү§иЎҢе®ҡж—¶еҸ‘еёғ - зҠ¶жҖҒжңәжөӢиҜ•")
    class ExecuteScheduledPublish {

        @Test
        @DisplayName("е®ҡж—¶еҸ‘еёғзҠ¶жҖҒеә”иҜҘеҸҜд»Ҙжү§иЎҢеҸ‘её?)
        void shouldExecuteScheduledPublish() {
            // Given
            Post post = Post.createDraft(1L, 123L, "ж Үйўҳ", "еҶ…е®№");
            post.schedulePublish(LocalDateTime.now().plusDays(1));

            // When
            post.executeScheduledPublish();

            // Then
            assertEquals(PostStatus.PUBLISHED, post.getStatus());
            assertTrue(post.isPublished());
            assertNotNull(post.getPublishedAt());
            assertNull(post.getScheduledAt());
        }

        @Test
        @DisplayName("йқһе®ҡж—¶еҸ‘еёғзҠ¶жҖҒжү§иЎҢеҸ‘еёғеә”иҜҘжҠӣеҮәејӮеё?)
        void shouldThrowExceptionWhenNotScheduled() {
            // Given
            Post post = Post.createDraft(1L, 123L, "ж Үйўҳ", "еҶ…е®№");

            // When & Then
            DomainException exception = assertThrows(DomainException.class, 
                    post::executeScheduledPublish);
            assertTrue(exception.getMessage().contains("е®ҡж—¶еҸ‘еёғзҠ¶жҖ?));
        }
    }

    @Nested
    @DisplayName("ж’Өеӣһж–Үз«  - зҠ¶жҖҒжңәжөӢиҜ•")
    class UnpublishPost {

        @Test
        @DisplayName("е·ІеҸ‘еёғзҠ¶жҖҒеә”иҜҘеҸҜд»Ҙж’Өеӣ?)
        void shouldUnpublishFromPublished() {
            // Given
            Post post = Post.createDraft(1L, 123L, "ж Үйўҳ", "еҶ…е®№");
            post.publish();

            // When
            post.unpublish();

            // Then
            assertEquals(PostStatus.DRAFT, post.getStatus());
            assertTrue(post.isDraft());
            assertNull(post.getPublishedAt());
        }

        @Test
        @DisplayName("иҚүзЁҝзҠ¶жҖҒж’Өеӣһеә”иҜҘжҠӣеҮәејӮеё?)
        void shouldThrowExceptionWhenUnpublishingDraft() {
            // Given
            Post post = Post.createDraft(1L, 123L, "ж Үйўҳ", "еҶ…е®№");

            // When & Then
            DomainException exception = assertThrows(DomainException.class, post::unpublish);
            assertTrue(exception.getMessage().contains("е·ІеҸ‘её?));
        }
    }

    @Nested
    @DisplayName("еҸ–ж¶Ҳе®ҡж—¶еҸ‘еёғ - зҠ¶жҖҒжңәжөӢиҜ•")
    class CancelSchedule {

        @Test
        @DisplayName("е®ҡж—¶еҸ‘еёғзҠ¶жҖҒеә”иҜҘеҸҜд»ҘеҸ–ж¶?)
        void shouldCancelSchedule() {
            // Given
            Post post = Post.createDraft(1L, 123L, "ж Үйўҳ", "еҶ…е®№");
            post.schedulePublish(LocalDateTime.now().plusDays(1));

            // When
            post.cancelSchedule();

            // Then
            assertEquals(PostStatus.DRAFT, post.getStatus());
            assertTrue(post.isDraft());
            assertNull(post.getScheduledAt());
        }

        @Test
        @DisplayName("йқһе®ҡж—¶еҸ‘еёғзҠ¶жҖҒеҸ–ж¶Ҳеә”иҜҘжҠӣеҮәејӮеё?)
        void shouldThrowExceptionWhenCancellingNonScheduled() {
            // Given
            Post post = Post.createDraft(1L, 123L, "ж Үйўҳ", "еҶ…е®№");

            // When & Then
            DomainException exception = assertThrows(DomainException.class, post::cancelSchedule);
            assertTrue(exception.getMessage().contains("е®ҡж—¶еҸ‘еёғзҠ¶жҖ?));
        }
    }

    @Nested
    @DisplayName("еҲ йҷӨж–Үз«  - зҠ¶жҖҒжңәжөӢиҜ•")
    class DeletePost {

        @Test
        @DisplayName("иҚүзЁҝзҠ¶жҖҒеә”иҜҘеҸҜд»ҘеҲ йҷ?)
        void shouldDeleteFromDraft() {
            // Given
            Post post = Post.createDraft(1L, 123L, "ж Үйўҳ", "еҶ…е®№");

            // When
            post.delete();

            // Then
            assertEquals(PostStatus.DELETED, post.getStatus());
            assertTrue(post.isDeleted());
        }

        @Test
        @DisplayName("е·ІеҸ‘еёғзҠ¶жҖҒеә”иҜҘеҸҜд»ҘеҲ йҷ?)
        void shouldDeleteFromPublished() {
            // Given
            Post post = Post.createDraft(1L, 123L, "ж Үйўҳ", "еҶ…е®№");
            post.publish();

            // When
            post.delete();

            // Then
            assertEquals(PostStatus.DELETED, post.getStatus());
            assertTrue(post.isDeleted());
        }

        @Test
        @DisplayName("е·ІеҲ йҷӨзҠ¶жҖҒйҮҚеӨҚеҲ йҷӨеә”иҜҘжҠӣеҮәејӮеё?)
        void shouldThrowExceptionWhenDeletingAlreadyDeleted() {
            // Given
            Post post = Post.createDraft(1L, 123L, "ж Үйўҳ", "еҶ…е®№");
            post.delete();

            // When & Then
            DomainException exception = assertThrows(DomainException.class, post::delete);
            assertTrue(exception.getMessage().contains("е·Із»ҸеҲ йҷӨ"));
        }
    }

    @Nested
    @DisplayName("жӣҙж–°еҶ…е®№")
    class UpdateContent {

        @Test
        @DisplayName("иҚүзЁҝзҠ¶жҖҒеә”иҜҘеҸҜд»Ҙжӣҙж–°еҶ…е®?)
        void shouldUpdateContentInDraft() {
            // Given
            Post post = Post.createDraft(1L, 123L, "еҺҹж Үйў?, "еҺҹеҶ…е®?);
            String newTitle = "ж–°ж Үйў?;
            String newContent = "ж–°еҶ…е®?;

            // When
            post.updateContent(newTitle, newContent);

            // Then
            assertEquals(newTitle, post.getTitle());
            assertEquals(newContent, post.getRaw());
        }

        @Test
        @DisplayName("е·ІеҸ‘еёғзҠ¶жҖҒеә”иҜҘеҸҜд»Ҙжӣҙж–°еҶ…е®?)
        void shouldUpdateContentInPublished() {
            // Given
            Post post = Post.createDraft(1L, 123L, "еҺҹж Үйў?, "еҺҹеҶ…е®?);
            post.publish();

            // When
            post.updateContent("ж–°ж Үйў?, "ж–°еҶ…е®?);

            // Then
            assertEquals("ж–°ж Үйў?, post.getTitle());
            assertEquals("ж–°еҶ…е®?, post.getRaw());
        }

        @Test
        @DisplayName("е·ІеҲ йҷӨзҠ¶жҖҒжӣҙж–°еҶ…е®№еә”иҜҘжҠӣеҮәејӮеё?)
        void shouldThrowExceptionWhenUpdatingDeleted() {
            // Given
            Post post = Post.createDraft(1L, 123L, "ж Үйўҳ", "еҶ…е®№");
            post.delete();

            // When & Then
            DomainException exception = assertThrows(DomainException.class, () ->
                    post.updateContent("ж–°ж Үйў?, "ж–°еҶ…е®?));
            assertTrue(exception.getMessage().contains("е·ІеҲ йҷ?));
        }

        @Test
        @DisplayName("ж ҮйўҳиҝҮй•ҝеә”иҜҘжҠӣеҮәејӮеёё")
        void shouldThrowExceptionWhenTitleTooLong() {
            // Given
            Post post = Post.createDraft(1L, 123L, "ж Үйўҳ", "еҶ…е®№");
            String longTitle = "a".repeat(201);

            // When & Then
            DomainException exception = assertThrows(DomainException.class, () ->
                    post.updateContent(longTitle, "еҶ…е®№"));
            assertTrue(exception.getMessage().contains("200"));
        }
    }

    @Nested
    @DisplayName("жҹҘиҜўж–№жі•")
    class QueryMethods {

        @Test
        @DisplayName("canBePublished еә”иҜҘжӯЈзЎ®еҲӨж–ӯ")
        void shouldCheckCanBePublished() {
            // Given
            Post draftWithContent = Post.createDraft(1L, 123L, "ж Үйўҳ", "еҶ…е®№");
            
            // Then
            assertTrue(draftWithContent.canBePublished());
        }

        @Test
        @DisplayName("isOwnedBy еә”иҜҘжӯЈзЎ®еҲӨж–ӯ")
        void shouldCheckOwnership() {
            // Given
            Post post = Post.createDraft(1L, 123L, "ж Үйўҳ", "еҶ…е®№");

            // Then
            assertTrue(post.isOwnedBy(123L));
            assertFalse(post.isOwnedBy(456L));
        }
    }
}

