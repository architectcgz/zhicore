package com.blog.post.domain.model;

import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Nested;
import org.junit.jupiter.api.Test;

import java.time.LocalDateTime;

import static org.junit.jupiter.api.Assertions.*;

/**
 * PostLike е®һдҪ“еҚ•е…ғжөӢиҜ•
 *
 * @author Blog Team
 */
@DisplayName("PostLike е®һдҪ“жөӢиҜ•")
class PostLikeTest {

    @Nested
    @DisplayName("еҲӣе»әзӮ№иөһ")
    class CreatePostLike {

        @Test
        @DisplayName("еә”иҜҘжҲҗеҠҹеҲӣе»әзӮ№иөһи®°еҪ•")
        void shouldCreatePostLikeSuccessfully() {
            // Given
            Long id = 1L;
            Long postId = 100L;
            Long userId = 123L;

            // When
            PostLike like = new PostLike(id, postId, userId);

            // Then
            assertNotNull(like);
            assertEquals(id, like.getId());
            assertEquals(postId, like.getPostId());
            assertEquals(userId, like.getUserId());
            assertNotNull(like.getCreatedAt());
        }

        @Test
        @DisplayName("зӮ№иөһIDдёәз©әж—¶еә”иҜҘжҠӣеҮәејӮеё?)
        void shouldThrowExceptionWhenIdIsNull() {
            assertThrows(IllegalArgumentException.class, () ->
                    new PostLike(null, 100L, 123L));
        }

        @Test
        @DisplayName("ж–Үз« IDдёәз©әж—¶еә”иҜҘжҠӣеҮәејӮеё?)
        void shouldThrowExceptionWhenPostIdIsNull() {
            assertThrows(IllegalArgumentException.class, () ->
                    new PostLike(1L, null, 123L));
        }

        @Test
        @DisplayName("з”ЁжҲ·IDдёәз©әж—¶еә”иҜҘжҠӣеҮәејӮеё?)
        void shouldThrowExceptionWhenUserIdIsEmpty() {
            assertThrows(IllegalArgumentException.class, () ->
                    new PostLike(1L, 100L, null));
        }
    }

    @Nested
    @DisplayName("д»ҺжҢҒд№…еҢ–жҒўеӨҚ")
    class Reconstitute {

        @Test
        @DisplayName("еә”иҜҘжҲҗеҠҹд»ҺжҢҒд№…еҢ–жҒўеӨҚзӮ№иөһи®°еҪ•")
        void shouldReconstituteSuccessfully() {
            // Given
            Long id = 1L;
            Long postId = 100L;
            Long userId = 123L;
            LocalDateTime createdAt = LocalDateTime.now().minusDays(1);

            // When
            PostLike like = PostLike.reconstitute(id, postId, userId, createdAt);

            // Then
            assertNotNull(like);
            assertEquals(id, like.getId());
            assertEquals(postId, like.getPostId());
            assertEquals(userId, like.getUserId());
            assertEquals(createdAt, like.getCreatedAt());
        }
    }
}

