package com.blog.post.application.service;

import com.blog.common.exception.BusinessException;
import com.blog.common.exception.ValidationException;
import com.blog.common.result.PageResult;
import com.blog.post.domain.model.Post;
import com.blog.post.domain.model.PostStats;
import com.blog.post.domain.repository.PostRepository;
import com.blog.post.interfaces.dto.response.PostManageDTO;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;

import java.util.Arrays;
import java.util.Collections;
import java.util.List;

import static org.assertj.core.api.Assertions.assertThat;
import static org.assertj.core.api.Assertions.assertThatThrownBy;
import static org.mockito.ArgumentMatchers.*;
import static org.mockito.Mockito.*;

/**
 * AdminPostApplicationService еҚ•е…ғжөӢиҜ•
 * жөӢиҜ•з®ЎзҗҶе‘ҳж–Үз« жҹҘиҜўеҠҹиғ?
 *
 * @author Blog Team
 */
@ExtendWith(MockitoExtension.class)
@DisplayName("AdminPostApplicationService жөӢиҜ•")
class AdminPostApplicationServiceTest {

    @Mock
    private PostRepository postRepository;

    @InjectMocks
    private AdminPostApplicationService adminPostApplicationService;

    @Test
    @DisplayName("жӯЈеёёжҹҘиҜўж–Үз« еҲ—иЎЁ")
    void testQueryPosts_success() {
        // Given
        List<Post> mockPosts = createMockPosts(10);
        when(postRepository.findByConditions(any(), any(), any(), anyInt(), anyInt()))
                .thenReturn(mockPosts);
        when(postRepository.countByConditions(any(), any(), any()))
                .thenReturn(10L);

        // When
        PageResult<PostManageDTO> result = adminPostApplicationService
                .queryPosts("test", "PUBLISHED", 123L, 1, 10);

        // Then
        assertThat(result.getRecords()).hasSize(10);
        assertThat(result.getTotal()).isEqualTo(10);
        assertThat(result.getCurrent()).isEqualTo(1);
        assertThat(result.getSize()).isEqualTo(10);
        
        verify(postRepository).findByConditions("test", "PUBLISHED", 123L, 0, 10);
        verify(postRepository).countByConditions("test", "PUBLISHED", 123L);
    }

    @Test
    @DisplayName("дҪҝз”Ёж— ж•ҲйЎөз Ғеә”дҪҝз”Ёй»ҳи®ӨеҖ?)
    void testQueryPosts_withInvalidPage() {
        // Given
        when(postRepository.findByConditions(any(), any(), any(), anyInt(), anyInt()))
                .thenReturn(Collections.emptyList());
        when(postRepository.countByConditions(any(), any(), any()))
                .thenReturn(0L);

        // When
        PageResult<PostManageDTO> result = adminPostApplicationService
                .queryPosts(null, null, null, -1, 10);

        // Then
        verify(postRepository).findByConditions(null, null, null, 0, 10);
    }

    @Test
    @DisplayName("дҪҝз”Ёж— ж•ҲйЎөйқўеӨ§е°Ҹеә”дҪҝз”Ёй»ҳи®ӨеҖ?)
    void testQueryPosts_withInvalidSize() {
        // Given
        when(postRepository.findByConditions(any(), any(), any(), anyInt(), anyInt()))
                .thenReturn(Collections.emptyList());
        when(postRepository.countByConditions(any(), any(), any()))
                .thenReturn(0L);

        // When
        PageResult<PostManageDTO> result = adminPostApplicationService
                .queryPosts(null, null, null, 1, -1);

        // Then
        verify(postRepository).findByConditions(null, null, null, 0, 20);
    }

    @Test
    @DisplayName("и¶…й•ҝе…ій”®иҜҚеә”жҠӣеҮәйӘҢиҜҒејӮеёё")
    void testQueryPosts_withLongKeyword() {
        // Given
        String longKeyword = "a".repeat(150);

        // When & Then
        assertThatThrownBy(() -> adminPostApplicationService
                .queryPosts(longKeyword, null, null, 1, 10))
                .isInstanceOf(BusinessException.class);
    }

    @Test
    @DisplayName("з©әе…ій”®иҜҚеә”иў«и§„иҢғеҢ–дёәnull")
    void testQueryPosts_withEmptyKeyword() {
        // Given
        when(postRepository.findByConditions(any(), any(), any(), anyInt(), anyInt()))
                .thenReturn(Collections.emptyList());
        when(postRepository.countByConditions(any(), any(), any()))
                .thenReturn(0L);

        // When
        adminPostApplicationService.queryPosts("  ", null, null, 1, 10);

        // Then
        verify(postRepository).findByConditions(null, null, null, 0, 10);
    }

    @Test
    @DisplayName("з©әзҷҪзҠ¶жҖҒеә”иў«и§„иҢғеҢ–дёәnull")
    void testQueryPosts_withEmptyStatus() {
        // Given
        when(postRepository.findByConditions(any(), any(), any(), anyInt(), anyInt()))
                .thenReturn(Collections.emptyList());
        when(postRepository.countByConditions(any(), any(), any()))
                .thenReturn(0L);

        // When
        adminPostApplicationService.queryPosts(null, "  ", null, 1, 10);

        // Then
        verify(postRepository).findByConditions(null, null, null, 0, 10);
    }

    @Test
    @DisplayName("зҠ¶жҖҒеә”иў«иҪ¬жҚўдёәеӨ§еҶҷ")
    void testQueryPosts_statusNormalization() {
        // Given
        when(postRepository.findByConditions(any(), any(), any(), anyInt(), anyInt()))
                .thenReturn(Collections.emptyList());
        when(postRepository.countByConditions(any(), any(), any()))
                .thenReturn(0L);

        // When
        adminPostApplicationService.queryPosts(null, "published", null, 1, 10);

        // Then
        verify(postRepository).findByConditions(null, "PUBLISHED", null, 0, 10);
    }

    @Test
    @DisplayName("и®Ўз®—жӯЈзЎ®зҡ„еҒҸз§»йҮҸ")
    void testQueryPosts_offsetCalculation() {
        // Given
        when(postRepository.findByConditions(any(), any(), any(), anyInt(), anyInt()))
                .thenReturn(Collections.emptyList());
        when(postRepository.countByConditions(any(), any(), any()))
                .thenReturn(0L);

        // When
        adminPostApplicationService.queryPosts(null, null, null, 3, 20);

        // Then
        verify(postRepository).findByConditions(null, null, null, 40, 20);
    }

    @Test
    @DisplayName("жӯЈзЎ®иҪ¬жҚўдёәDTO")
    void testQueryPosts_dtoConversion() {
        // Given
        Post post = Post.createDraft(1L, 123L, "жөӢиҜ•ж–Үз« ", "еҶ…е®№");
        when(postRepository.findByConditions(any(), any(), any(), anyInt(), anyInt()))
                .thenReturn(Collections.singletonList(post));
        when(postRepository.countByConditions(any(), any(), any()))
                .thenReturn(1L);

        // When
        PageResult<PostManageDTO> result = adminPostApplicationService
                .queryPosts(null, null, null, 1, 10);

        // Then
        assertThat(result.getRecords()).hasSize(1);
        PostManageDTO dto = result.getRecords().get(0);
        assertThat(dto.getId()).isEqualTo(1L);
        assertThat(dto.getTitle()).isEqualTo("жөӢиҜ•ж–Үз« ");
        assertThat(dto.getAuthorId()).isEqualTo(123L);
        assertThat(dto.getStatus()).isEqualTo("DRAFT");
    }

    @Test
    @DisplayName("жҹҘиҜўз»“жһңдёәз©ә")
    void testQueryPosts_emptyResult() {
        // Given
        when(postRepository.findByConditions(any(), any(), any(), anyInt(), anyInt()))
                .thenReturn(Collections.emptyList());
        when(postRepository.countByConditions(any(), any(), any()))
                .thenReturn(0L);

        // When
        PageResult<PostManageDTO> result = adminPostApplicationService
                .queryPosts("дёҚеӯҳең?, null, null, 1, 10);

        // Then
        assertThat(result.getRecords()).isEmpty();
        assertThat(result.getTotal()).isZero();
    }

    @Test
    @DisplayName("жҹҘиҜўеӨҡзҜҮж–Үз« ")
    void testQueryPosts_multipleResults() {
        // Given
        List<Post> mockPosts = createMockPosts(5);
        when(postRepository.findByConditions(any(), any(), any(), anyInt(), anyInt()))
                .thenReturn(mockPosts);
        when(postRepository.countByConditions(any(), any(), any()))
                .thenReturn(5L);

        // When
        PageResult<PostManageDTO> result = adminPostApplicationService
                .queryPosts(null, null, null, 1, 10);

        // Then
        assertThat(result.getRecords()).hasSize(5);
        assertThat(result.getTotal()).isEqualTo(5);
    }

    @Test
    @DisplayName("RepositoryејӮеёёеә”иў«еҢ…иЈ…дёәBusinessException")
    void testQueryPosts_repositoryException() {
        // Given
        when(postRepository.findByConditions(any(), any(), any(), anyInt(), anyInt()))
                .thenThrow(new RuntimeException("Database error"));

        // When & Then
        assertThatThrownBy(() -> adminPostApplicationService
                .queryPosts(null, null, null, 1, 10))
                .isInstanceOf(BusinessException.class)
                .hasMessageContaining("жҹҘиҜўж–Үз« еҲ—иЎЁеӨұиҙҘ");
    }

    @Test
    @DisplayName("CountејӮеёёеә”иў«еҢ…иЈ…дёәBusinessException")
    void testQueryPosts_countException() {
        // Given
        when(postRepository.findByConditions(any(), any(), any(), anyInt(), anyInt()))
                .thenReturn(Collections.emptyList());
        when(postRepository.countByConditions(any(), any(), any()))
                .thenThrow(new RuntimeException("Database error"));

        // When & Then
        assertThatThrownBy(() -> adminPostApplicationService
                .queryPosts(null, null, null, 1, 10))
                .isInstanceOf(BusinessException.class)
                .hasMessageContaining("жҹҘиҜўж–Үз« еҲ—иЎЁеӨұиҙҘ");
    }

    // ==================== иҫ…еҠ©ж–№жі• ====================

    private List<Post> createMockPosts(int count) {
        List<Post> posts = new java.util.ArrayList<>();
        for (int i = 0; i < count; i++) {
            posts.add(Post.createDraft(System.nanoTime() + i, 123L, "жөӢиҜ•ж–Үз« ", "еҶ…е®№"));
        }
        return posts;
    }
}

