package com.blog.post.infrastructure.service;

import com.blog.post.domain.model.Post;
import com.blog.post.domain.model.PostStatus;
import com.blog.post.domain.repository.PostRepository;
import com.blog.post.domain.service.ArchiveManager;
import com.blog.post.infrastructure.mongodb.document.PostContent;
import com.blog.post.infrastructure.mongodb.repository.PostArchiveRepository;
import com.blog.post.infrastructure.mongodb.repository.PostContentRepository;
import net.jqwik.api.*;
import net.jqwik.api.constraints.IntRange;
import net.jqwik.api.constraints.StringLength;
import net.jqwik.time.api.DateTimes;
import org.junit.jupiter.api.BeforeEach;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.context.SpringBootTest;
import org.springframework.test.context.DynamicPropertyRegistry;
import org.springframework.test.context.DynamicPropertySource;
import org.testcontainers.containers.MongoDBContainer;
import org.testcontainers.containers.PostgreSQLContainer;
import org.testcontainers.junit.jupiter.Container;
import org.testcontainers.junit.jupiter.Testcontainers;

import java.time.LocalDateTime;
import java.time.temporal.ChronoUnit;
import java.util.ArrayList;
import java.util.List;
import java.util.Optional;

import static org.assertj.core.api.Assertions.assertThat;

/**
 * Archive Manager Cold Data Identification Property Test
 * 
 * Uses property-based testing to validate that posts are correctly
 * identified as cold data candidates based on their last update time.
 * 
 * **Feature: post-mongodb-hybrid, Property 18: 冷数据识别准确性**
 * 
 * **Validates: Requirements 6.1**
 * 
 * Property 18: 冷数据识别准确性
 * 对于任意文章，如果其更新时间距离当前时间超过配置的阈值（如 6 个月），则应该被标记为冷数据候选。
 */
@SpringBootTest
@Testcontainers
class ArchiveManagerColdDataIdentificationPropertyTest {

    @Container
    static PostgreSQLContainer<?> postgres = new PostgreSQLContainer<>("postgres:16-alpine")
            .withDatabaseName("test")
            .withUsername("test")
            .withPassword("test");

    @Container
    static MongoDBContainer mongoDBContainer = new MongoDBContainer("mongo:8.0")
            .withExposedPorts(27017);

    @DynamicPropertySource
    static void setProperties(DynamicPropertyRegistry registry) {
        registry.add("spring.datasource.url", postgres::getJdbcUrl);
        registry.add("spring.datasource.username", postgres::getUsername);
        registry.add("spring.datasource.password", postgres::getPassword);
        registry.add("spring.data.mongodb.uri", mongoDBContainer::getReplicaSetUrl);
    }

    @Autowired
    private ArchiveManager archiveManager;

    @Autowired
    private PostRepository postRepository;

    @Autowired
    private PostContentRepository contentRepository;

    @Autowired
    private PostArchiveRepository archiveRepository;

    @BeforeEach
    void setUp() {
        archiveRepository.deleteAll();
        contentRepository.deleteAll();
        // Note: PostRepository cleanup handled by @Transactional rollback
    }

    /**
     * Property 18: Posts older than threshold are cold data candidates
     * 
     * For any post, if its updatedAt time is more than the threshold (e.g., 180 days)
     * before the current time, it should be identified as a cold data candidate.
     * 
     * **Validates: Requirements 6.1**
     */
    @Property(tries = 100)
    @Label("Property 18: Posts older than threshold are cold data candidates")
    void postsOlderThanThresholdAreColdDataCandidates(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @IntRange(min = 1, max = 100000) long ownerId,
            @ForAll @StringLength(min = 5, max = 100) String title,
            @ForAll @IntRange(min = 181, max = 730) int daysOld) {

        // Given: A post that was last updated more than 180 days ago (cold data)
        LocalDateTime oldUpdateTime = LocalDateTime.now().minusDays(daysOld);
        
        Post post = createPostWithUpdateTime(postId, ownerId, title, oldUpdateTime);
        postRepository.save(post);
        
        // Create content in MongoDB
        createPostContent(String.valueOf(postId), title);

        // When: Check if the post should be archived based on 180-day threshold
        int thresholdDays = 180;
        LocalDateTime thresholdTime = LocalDateTime.now().minusDays(thresholdDays);
        
        // Then: Post's update time should be before the threshold (cold data)
        assertThat(post.getUpdatedAt())
                .as("Post updated %d days ago should be before %d-day threshold", daysOld, thresholdDays)
                .isBefore(thresholdTime);
        
        // Verify the post qualifies for archiving
        long daysSinceUpdate = ChronoUnit.DAYS.between(post.getUpdatedAt(), LocalDateTime.now());
        assertThat(daysSinceUpdate)
                .as("Days since update should be greater than threshold")
                .isGreaterThan(thresholdDays);
    }

    /**
     * Property 18: Posts newer than threshold are NOT cold data candidates
     * 
     * For any post, if its updatedAt time is within the threshold period,
     * it should NOT be identified as a cold data candidate.
     * 
     * **Validates: Requirements 6.1**
     */
    @Property(tries = 100)
    @Label("Property 18: Posts newer than threshold are NOT cold data candidates")
    void postsNewerThanThresholdAreNotColdDataCandidates(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @IntRange(min = 1, max = 100000) long ownerId,
            @ForAll @StringLength(min = 5, max = 100) String title,
            @ForAll @IntRange(min = 0, max = 179) int daysOld) {

        // Given: A post that was last updated within the last 180 days (hot data)
        LocalDateTime recentUpdateTime = LocalDateTime.now().minusDays(daysOld);
        
        Post post = createPostWithUpdateTime(postId, ownerId, title, recentUpdateTime);
        postRepository.save(post);
        
        // Create content in MongoDB
        createPostContent(String.valueOf(postId), title);

        // When: Check if the post should be archived based on 180-day threshold
        int thresholdDays = 180;
        LocalDateTime thresholdTime = LocalDateTime.now().minusDays(thresholdDays);
        
        // Then: Post's update time should be after the threshold (hot data)
        assertThat(post.getUpdatedAt())
                .as("Post updated %d days ago should be after %d-day threshold", daysOld, thresholdDays)
                .isAfterOrEqualTo(thresholdTime);
        
        // Verify the post does NOT qualify for archiving
        long daysSinceUpdate = ChronoUnit.DAYS.between(post.getUpdatedAt(), LocalDateTime.now());
        assertThat(daysSinceUpdate)
                .as("Days since update should be less than or equal to threshold")
                .isLessThanOrEqualTo(thresholdDays);
    }

    /**
     * Property 18: Threshold boundary is correctly identified
     * 
     * For any post exactly at the threshold boundary (e.g., 180 days),
     * the system should consistently classify it based on the threshold rule.
     * 
     * **Validates: Requirements 6.1**
     */
    @Property(tries = 100)
    @Label("Property 18: Threshold boundary is correctly identified")
    void thresholdBoundaryIsCorrectlyIdentified(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @IntRange(min = 1, max = 100000) long ownerId,
            @ForAll @StringLength(min = 5, max = 100) String title) {

        // Given: A post exactly at the 180-day threshold
        int thresholdDays = 180;
        LocalDateTime exactThresholdTime = LocalDateTime.now().minusDays(thresholdDays);
        
        Post post = createPostWithUpdateTime(postId, ownerId, title, exactThresholdTime);
        postRepository.save(post);
        
        // Create content in MongoDB
        createPostContent(String.valueOf(postId), title);

        // When: Calculate days since update
        long daysSinceUpdate = ChronoUnit.DAYS.between(post.getUpdatedAt(), LocalDateTime.now());
        
        // Then: Days should be approximately equal to threshold (allowing for test execution time)
        assertThat(daysSinceUpdate)
                .as("Days since update should be at or near threshold")
                .isBetween((long) thresholdDays, (long) thresholdDays + 1);
    }

    /**
     * Property 18: Multiple posts with different ages are correctly classified
     * 
     * For any set of posts with varying update times, each post should be
     * correctly classified as cold or hot data based on the threshold.
     * 
     * **Validates: Requirements 6.1**
     */
    @Property(tries = 50)
    @Label("Property 18: Multiple posts with different ages are correctly classified")
    void multiplePostsWithDifferentAgesAreCorrectlyClassified(
            @ForAll("postAgeList") List<Integer> postAges,
            @ForAll @IntRange(min = 1, max = 100000) long baseOwnerId,
            @ForAll @StringLength(min = 5, max = 50) String baseTitle) {

        // Given: Multiple posts with different ages
        int thresholdDays = 180;
        List<Post> posts = new ArrayList<>();
        
        for (int i = 0; i < postAges.size(); i++) {
            int daysOld = postAges.get(i);
            long postId = 1000000L + i;
            LocalDateTime updateTime = LocalDateTime.now().minusDays(daysOld);
            
            Post post = createPostWithUpdateTime(postId, baseOwnerId, baseTitle + " " + i, updateTime);
            postRepository.save(post);
            createPostContent(String.valueOf(postId), baseTitle + " " + i);
            posts.add(post);
        }

        // When: Classify each post
        LocalDateTime thresholdTime = LocalDateTime.now().minusDays(thresholdDays);
        int coldDataCount = 0;
        int hotDataCount = 0;

        for (int i = 0; i < posts.size(); i++) {
            Post post = posts.get(i);
            int daysOld = postAges.get(i);
            
            // Then: Verify classification matches expected result
            if (daysOld > thresholdDays) {
                // Should be cold data
                assertThat(post.getUpdatedAt())
                        .as("Post %d (%d days old) should be cold data", i, daysOld)
                        .isBefore(thresholdTime);
                coldDataCount++;
            } else {
                // Should be hot data
                assertThat(post.getUpdatedAt())
                        .as("Post %d (%d days old) should be hot data", i, daysOld)
                        .isAfterOrEqualTo(thresholdTime);
                hotDataCount++;
            }
        }

        // Verify we have a mix of cold and hot data (if input allows)
        long expectedColdCount = postAges.stream().filter(age -> age > thresholdDays).count();
        long expectedHotCount = postAges.stream().filter(age -> age <= thresholdDays).count();
        
        assertThat(coldDataCount).isEqualTo(expectedColdCount);
        assertThat(hotDataCount).isEqualTo(expectedHotCount);
    }

    /**
     * Property 18: Archived posts are correctly identified as cold data
     * 
     * For any post that has been archived, it should have been cold data
     * at the time of archiving (update time older than threshold).
     * 
     * **Validates: Requirements 6.1**
     */
    @Property(tries = 100)
    @Label("Property 18: Archived posts were cold data at archiving time")
    void archivedPostsWereColdDataAtArchivingTime(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @IntRange(min = 1, max = 100000) long ownerId,
            @ForAll @StringLength(min = 5, max = 100) String title,
            @ForAll @IntRange(min = 181, max = 365) int daysOld) {

        // Given: A post that is old enough to be archived
        LocalDateTime oldUpdateTime = LocalDateTime.now().minusDays(daysOld);
        
        Post post = createPostWithUpdateTime(postId, ownerId, title, oldUpdateTime);
        postRepository.save(post);
        
        // Create content in MongoDB
        createPostContent(String.valueOf(postId), title);

        // When: Archive the post
        try {
            archiveManager.archivePost(String.valueOf(postId), "time");
            
            // Then: Verify the post was cold data (older than 180 days)
            int thresholdDays = 180;
            long daysSinceUpdate = ChronoUnit.DAYS.between(oldUpdateTime, LocalDateTime.now());
            
            assertThat(daysSinceUpdate)
                    .as("Archived post should have been older than %d days", thresholdDays)
                    .isGreaterThan(thresholdDays);
            
            // Verify post is marked as archived
            Optional<Post> archivedPost = postRepository.findById(String.valueOf(postId));
            assertThat(archivedPost).isPresent();
            assertThat(archivedPost.get().isArchived())
                    .as("Post should be marked as archived")
                    .isTrue();
                    
        } catch (Exception e) {
            // Archive operation may fail for various reasons, but the cold data
            // identification logic should still be correct
            int thresholdDays = 180;
            long daysSinceUpdate = ChronoUnit.DAYS.between(oldUpdateTime, LocalDateTime.now());
            
            assertThat(daysSinceUpdate)
                    .as("Post should still be identified as cold data even if archiving fails")
                    .isGreaterThan(thresholdDays);
        }
    }

    /**
     * Property 18: Recently updated posts are never cold data
     * 
     * For any post that was updated today or recently, it should never
     * be identified as cold data regardless of its creation date.
     * 
     * **Validates: Requirements 6.1**
     */
    @Property(tries = 100)
    @Label("Property 18: Recently updated posts are never cold data")
    void recentlyUpdatedPostsAreNeverColdData(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @IntRange(min = 1, max = 100000) long ownerId,
            @ForAll @StringLength(min = 5, max = 100) String title,
            @ForAll @IntRange(min = 0, max = 7) int daysAgo) {

        // Given: A post that was updated very recently (within last week)
        LocalDateTime recentUpdateTime = LocalDateTime.now().minusDays(daysAgo);
        
        Post post = createPostWithUpdateTime(postId, ownerId, title, recentUpdateTime);
        postRepository.save(post);
        
        // Create content in MongoDB
        createPostContent(String.valueOf(postId), title);

        // When: Check against threshold
        int thresholdDays = 180;
        LocalDateTime thresholdTime = LocalDateTime.now().minusDays(thresholdDays);
        
        // Then: Post should definitely be hot data
        assertThat(post.getUpdatedAt())
                .as("Recently updated post should be after threshold")
                .isAfter(thresholdTime);
        
        long daysSinceUpdate = ChronoUnit.DAYS.between(post.getUpdatedAt(), LocalDateTime.now());
        assertThat(daysSinceUpdate)
                .as("Days since update should be much less than threshold")
                .isLessThan(thresholdDays);
    }

    /**
     * Property 18: Cold data identification is independent of post status
     * 
     * For any post, cold data identification should be based solely on
     * update time, not on post status (draft, published, etc.).
     * 
     * **Validates: Requirements 6.1**
     */
    @Property(tries = 100)
    @Label("Property 18: Cold data identification is independent of post status")
    void coldDataIdentificationIsIndependentOfPostStatus(
            @ForAll @IntRange(min = 1, max = 1000000) long postId,
            @ForAll @IntRange(min = 1, max = 100000) long ownerId,
            @ForAll @StringLength(min = 5, max = 100) String title,
            @ForAll @IntRange(min = 181, max = 365) int daysOld,
            @ForAll("postStatus") PostStatus status) {

        // Given: A post with any status that is old enough to be cold data
        LocalDateTime oldUpdateTime = LocalDateTime.now().minusDays(daysOld);
        
        Post post = createPostWithUpdateTimeAndStatus(postId, ownerId, title, oldUpdateTime, status);
        postRepository.save(post);
        
        // Create content in MongoDB
        createPostContent(String.valueOf(postId), title);

        // When: Check if post is cold data
        int thresholdDays = 180;
        long daysSinceUpdate = ChronoUnit.DAYS.between(post.getUpdatedAt(), LocalDateTime.now());
        
        // Then: Post should be cold data regardless of status
        assertThat(daysSinceUpdate)
                .as("Post with status %s should be cold data based on age alone", status)
                .isGreaterThan(thresholdDays);
        
        // Verify status doesn't affect cold data classification
        LocalDateTime thresholdTime = LocalDateTime.now().minusDays(thresholdDays);
        assertThat(post.getUpdatedAt())
                .as("Post update time should be before threshold regardless of status")
                .isBefore(thresholdTime);
    }

    // Helper methods

    private Post createPostWithUpdateTime(long postId, long ownerId, String title, LocalDateTime updateTime) {
        return Post.reconstitute(
                postId,
                ownerId,
                title,
                null, // excerpt
                null, // coverImage
                PostStatus.PUBLISHED,
                null, // topicId
                updateTime.minusDays(1), // publishedAt
                null, // scheduledAt
                updateTime.minusDays(30), // createdAt
                updateTime, // updatedAt
                false, // isArchived
                null // stats
        );
    }

    private Post createPostWithUpdateTimeAndStatus(long postId, long ownerId, String title, 
                                                   LocalDateTime updateTime, PostStatus status) {
        return Post.reconstitute(
                postId,
                ownerId,
                title,
                null, // excerpt
                null, // coverImage
                status,
                null, // topicId
                status == PostStatus.PUBLISHED ? updateTime.minusDays(1) : null, // publishedAt
                null, // scheduledAt
                updateTime.minusDays(30), // createdAt
                updateTime, // updatedAt
                false, // isArchived
                null // stats
        );
    }

    private void createPostContent(String postId, String title) {
        PostContent content = PostContent.builder()
                .postId(postId)
                .contentType("markdown")
                .raw("Content for " + title)
                .html("<p>Content for " + title + "</p>")
                .text("Content for " + title)
                .createdAt(LocalDateTime.now())
                .updatedAt(LocalDateTime.now())
                .build();
        contentRepository.save(content);
    }

    // Data generators

    @Provide
    Arbitrary<List<Integer>> postAgeList() {
        return Arbitraries.integers()
                .between(0, 730) // 0 to 2 years
                .list()
                .ofMinSize(3)
                .ofMaxSize(10);
    }

    @Provide
    Arbitrary<PostStatus> postStatus() {
        return Arbitraries.of(PostStatus.DRAFT, PostStatus.PUBLISHED, PostStatus.SCHEDULED);
    }
}
