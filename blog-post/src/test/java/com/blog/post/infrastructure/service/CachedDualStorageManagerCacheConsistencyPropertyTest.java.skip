package com.blog.post.infrastructure.service;

import com.blog.common.cache.HotDataIdentifier;
import com.blog.common.config.CacheProperties;
import com.blog.post.domain.model.PostContent;
import com.blog.post.infrastructure.cache.PostRedisKeys;
import net.jqwik.api.*;
import org.junit.jupiter.api.BeforeEach;
import org.mockito.ArgumentCaptor;
import org.mockito.Mock;
import org.mockito.MockitoAnnotations;
import org.redisson.api.RLock;
import org.redisson.api.RedissonClient;
import org.springframework.data.redis.core.RedisTemplate;
import org.springframework.data.redis.core.ValueOperations;

import java.util.concurrent.TimeUnit;

import static org.assertj.core.api.Assertions.assertThat;
import static org.mockito.ArgumentMatchers.*;
import static org.mockito.Mockito.*;

/**
 * Feature: cache-penetration-protection, Property 3: 缓存填充后的一致性
 * Validates: Requirements 1.3
 * 
 * Property: For any entity data, after caching, the cached value should match
 * the database value.
 */
class CachedDualStorageManagerCacheConsistencyPropertyTest {

    @Mock
    private DualStorageManager delegate;
    
    @Mock
    private RedisTemplate<String, Object> redisTemplate;
    
    @Mock
    private RedissonClient redissonClient;
    
    @Mock
    private HotDataIdentifier hotDataIdentifier;
    
    @Mock
    private ValueOperations<String, Object> valueOperations;
    
    @Mock
    private RLock lock;
    
    private CacheProperties cacheProperties;
    private CachedDualStorageManager cachedManager;

    @BeforeEach
    void setUp() {
        MockitoAnnotations.openMocks(this);
        
        cacheProperties = new CacheProperties();
        cacheProperties.setEntityDetail(600);
        cacheProperties.setLockWaitTime(5);
        cacheProperties.setLockLeaseTime(10);
        cacheProperties.setNullValueTtl(60);
        cacheProperties.setHotDataIdentificationEnabled(true);
        
        cachedManager = new CachedDualStorageManager(
            delegate,
            redisTemplate,
            redissonClient,
            hotDataIdentifier,
            cacheProperties
        );
        
        when(redisTemplate.opsForValue()).thenReturn(valueOperations);
    }

    /**
     * Property 3: 缓存填充后的一致性
     * For any entity data, cached value should match database value
     */
    @Property(tries = 100)
    void cacheConsistencyAfterFill(
        @ForAll @LongRange(min = 1, max = 10000) Long postId,
        @ForAll @StringLength(min = 1, max = 100) String title,
        @ForAll @StringLength(min = 10, max = 500) String content
    ) throws Exception {
        // Given: Cache miss and hot data
        String cacheKey = PostRedisKeys.content(postId);
        String lockKey = PostRedisKeys.lockContent(postId);
        
        when(valueOperations.get(cacheKey)).thenReturn(null);
        when(hotDataIdentifier.isHotData("post", postId)).thenReturn(true);
        when(hotDataIdentifier.isManuallyMarkedAsHot("post", postId)).thenReturn(false);
        when(redissonClient.getLock(lockKey)).thenReturn(lock);
        when(lock.tryLock(anyLong(), anyLong(), any(TimeUnit.class))).thenReturn(true);
        when(lock.isHeldByCurrentThread()).thenReturn(true);
        
        PostContent dbContent = new PostContent();
        dbContent.setPostId(postId.toString());
        dbContent.setTitle(title);
        dbContent.setRaw(content);
        
        when(delegate.getPostContent(postId)).thenReturn(dbContent);
        
        // When: Get post content (will load from DB and cache)
        PostContent result = cachedManager.getPostContent(postId);
        
        // Then: Result should match database content
        assertThat(result).isNotNull();
        assertThat(result.getPostId()).isEqualTo(dbContent.getPostId());
        assertThat(result.getTitle()).isEqualTo(dbContent.getTitle());
        assertThat(result.getRaw()).isEqualTo(dbContent.getRaw());
        
        // Verify cached value matches database value
        ArgumentCaptor<Object> cachedValueCaptor = ArgumentCaptor.forClass(Object.class);
        verify(valueOperations).set(eq(cacheKey), cachedValueCaptor.capture(), anyLong(), any(TimeUnit.class));
        
        PostContent cachedContent = (PostContent) cachedValueCaptor.getValue();
        assertThat(cachedContent.getPostId()).isEqualTo(dbContent.getPostId());
        assertThat(cachedContent.getTitle()).isEqualTo(dbContent.getTitle());
        assertThat(cachedContent.getRaw()).isEqualTo(dbContent.getRaw());
    }
}
