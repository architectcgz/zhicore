# ===========================================
# ZhiCore Microservice Environment Variables
# ===========================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# ===========================================

# Database Configuration
DB_USERNAME=postgres
DB_PASSWORD=your_database_password_here

# Redis Configuration
REDIS_PASSWORD=your_redis_password_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_at_least_32_characters_long

# Elasticsearch Configuration (可选)
ES_USERNAME=
ES_PASSWORD=

# ID Generator Service URL (可选，默认使用 host.docker.internal:8011)
# ID_GENERATOR_SERVER_URL=http://host.docker.internal:8011
